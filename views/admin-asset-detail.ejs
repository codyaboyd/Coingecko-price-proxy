<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/public/css/app.css" rel="stylesheet">
  </head>
  <body>
    <nav class="navbar navbar-expand-lg bg-dark navbar-dark">
      <div class="container">
        <a class="navbar-brand" href="/admin"><%= appName %></a>
        <div class="navbar-nav ms-auto">
          <a class="nav-link" href="/admin/assets">Assets</a>
          <a class="nav-link" href="/admin/system-health">System Health</a>
          <a class="nav-link" href="/admin/db-integrity">DB Integrity</a>
          <a class="nav-link" href="/admin/rate-budget">Rate Budget</a>
          <a class="nav-link" href="/admin/api-test">API Test</a>
          <a class="nav-link" href="/admin/logout">Logout</a>
        </div>
      </div>
    </nav>

    <%- include('admin-maintenance-banner') %>

    <main class="container py-5">
      <div class="mb-4">
        <a href="/admin" class="btn btn-sm btn-outline-secondary">&larr; Back to assets</a>
      </div>

      <div class="row g-4">
        <section class="col-lg-5">
          <div class="card shadow-sm mb-4">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
              <h1 class="h4 mb-0"><%= asset.symbol %> asset metadata</h1>
              <% if (asset.enabled) { %>
                <span class="badge text-bg-success">Enabled</span>
              <% } else { %>
                <span class="badge text-bg-secondary">Disabled</span>
              <% } %>
            </div>
            <div class="card-body">
              <dl class="row mb-0">
                <dt class="col-sm-5">Asset ID</dt>
                <dd class="col-sm-7"><code><%= asset.id %></code></dd>
                <dt class="col-sm-5">Name</dt>
                <dd class="col-sm-7"><%= asset.name %></dd>
                <dt class="col-sm-5">Symbol</dt>
                <dd class="col-sm-7"><%= asset.symbol %></dd>
                <dt class="col-sm-5">CoinGecko ID</dt>
                <dd class="col-sm-7"><code><%= asset.coingeckoId %></code></dd>
                <dt class="col-sm-5">Default currency</dt>
                <dd class="col-sm-7 text-uppercase"><%= asset.vsCurrency %></dd>
                <dt class="col-sm-5">Priority</dt>
                <dd class="col-sm-7"><%= asset.priority %></dd>
              </dl>
            </div>
          </div>

          <div class="card shadow-sm mb-4">
            <div class="card-header bg-white">
              <h2 class="h5 mb-0">Local candle coverage</h2>
            </div>
            <div class="card-body">
              <dl class="mb-0">
                <dt>Total candles</dt>
                <dd><%= candleSummary.count %></dd>
                <dt>Earliest candle</dt>
                <dd><%= candleSummary.earliestIso || 'No candles stored yet' %></dd>
                <dt>Latest candle</dt>
                <dd><%= candleSummary.latestIso || 'No candles stored yet' %></dd>
              </dl>
            </div>
          </div>

          <div class="card shadow-sm mb-4">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
              <h2 class="h5 mb-0">Staleness status</h2>
              <% const stalenessBadgeClasses = { fresh: 'success', stale: 'warning', empty: 'secondary', fetching: 'info', failed: 'danger' }; %>
              <span class="badge text-bg-<%= stalenessBadgeClasses[staleness.overallStatus] || 'secondary' %>"><%= staleness.overallStatus %></span>
            </div>
            <div class="card-body">
              <div class="vstack gap-2">
                <% staleness.intervals.forEach((intervalStatus) => { %>
                  <div class="border rounded p-2">
                    <div class="d-flex justify-content-between align-items-center">
                      <strong><%= intervalStatus.interval %></strong>
                      <span class="badge text-bg-<%= stalenessBadgeClasses[intervalStatus.status] || 'secondary' %>"><%= intervalStatus.status %></span>
                    </div>
                    <div class="small text-body-secondary">Latest candle: <%= intervalStatus.latestTsIso || 'none' %>; stale after <%= intervalStatus.staleAfterMinutes %> minutes.</div>
                    <% if (intervalStatus.lastError) { %>
                      <div class="small text-danger">Last error: <%= intervalStatus.lastError %></div>
                    <% } %>
                    <% if (intervalStatus.failure && intervalStatus.failure.inCooldown) { %>
                      <div class="small text-danger">Cooling down until <%= intervalStatus.failure.cooldownUntilIso %>.</div>
                    <% } %>
                  </div>
                <% }) %>
              </div>
              <div class="d-flex flex-wrap gap-2 mt-3">
                <form method="post" action="/admin/scheduler/repair-stale">
                  <button type="submit" class="btn btn-danger">Repair stale data now</button>
                </form>
                <a class="btn btn-outline-secondary" href="/api/v1/admin/assets/<%= encodeURIComponent(asset.id) %>/staleness">GET staleness JSON</a>
              </div>
            </div>
          </div>

          <div class="card shadow-sm">
            <div class="card-header bg-white">
              <h2 class="h5 mb-0">Local API test</h2>
            </div>
            <div class="card-body">
              <p class="text-body-secondary">Open the history API test page preselecting this asset, or call the JSON endpoint directly.</p>
              <div class="d-flex flex-wrap gap-2">
                <a class="btn btn-outline-primary" href="/admin/api-test?asset=<%= encodeURIComponent(asset.id) %>">Open API test</a>
                <a class="btn btn-outline-secondary" href="/api/v1/history/<%= encodeURIComponent(asset.id) %>?interval=1h&vs=<%= encodeURIComponent(asset.vsCurrency) %>">GET local history</a>
              </div>
            </div>
          </div>
        </section>

        <section class="col-lg-7">
          <div class="card shadow-sm mb-4">
            <div class="card-header bg-white">
              <h2 class="h5 mb-0">Manual CoinGecko fetch</h2>
            </div>
            <div class="card-body">
              <form id="fetchForm" class="vstack gap-3">
                <div class="row g-3">
                  <div class="col-sm-6">
                    <label for="from" class="form-label">From</label>
                    <input id="from" type="date" class="form-control" value="2024-01-01" required>
                  </div>
                  <div class="col-sm-6">
                    <label for="to" class="form-label">To</label>
                    <input id="to" type="date" class="form-control" value="2024-02-01" required>
                  </div>
                </div>

                <div class="row g-3">
                  <div class="col-sm-4">
                    <label for="interval" class="form-label">Interval</label>
                    <select id="interval" class="form-select">
                      <option value="1h" selected>1 hour</option>
                      <option value="1d">1 day</option>
                      <option value="5m">5 minutes</option>
                    </select>
                  </div>
                  <div class="col-sm-4">
                    <label for="vsCurrency" class="form-label">Currency</label>
                    <input id="vsCurrency" class="form-control" value="<%= asset.vsCurrency %>" required>
                  </div>
                  <div class="col-sm-4">
                    <label for="conflictPolicy" class="form-label">Conflict policy</label>
                    <select id="conflictPolicy" class="form-select">
                      <option value="fill_only_missing" selected>Fill only missing</option>
                      <option value="skip_existing">Skip existing</option>
                      <option value="overwrite_existing">Overwrite existing</option>
                    </select>
                  </div>
                </div>

                <div class="d-flex flex-wrap align-items-center gap-2">
                  <button type="button" id="checkExistingButton" class="btn btn-outline-secondary">Check local data</button>
                  <button type="submit" class="btn btn-primary">Queue manual fetch</button>
                  <button type="button" id="backfillButton" class="btn btn-outline-primary">Queue backfill</button>
                  <span id="fetchStatus" class="badge text-bg-secondary">Not run</span>
                </div>
              </form>

              <div id="rateBudgetWarning" class="alert alert-warning mt-3 mb-0" role="alert">
                Rate budget: <strong><%= rateBudget.safeRemainingCalls %></strong> safe calls remain this minute; queued work is estimated at <strong><%= rateBudget.queueEstimatedCalls %></strong> calls.
                Large manual fetches and backfills will show a confirmation before queueing.
              </div>
              <div id="existingDataSummary" class="alert alert-secondary mt-3 mb-0" role="status">
                Check local data to see whether candles already exist before fetching.
              </div>
              <pre id="fetchResponse" class="bg-body-tertiary border rounded p-3 mt-3 mb-0 small" style="min-height: 12rem; white-space: pre-wrap;">Queue a manual fetch or backfill for this asset.</pre>
            </div>
          </div>

          <div class="card shadow-sm mb-4">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
              <h2 class="h5 mb-0">Gap report</h2>
              <span id="gapStatus" class="badge text-bg-secondary">Not run</span>
            </div>
            <div class="card-body">
              <p class="text-body-secondary">Run a local coverage report for the selected fetch range without starting a backfill.</p>
              <button type="button" id="runGapReportButton" class="btn btn-outline-primary">Run gap report</button>
              <div id="gapSummary" class="row g-3 mt-1"></div>
              <pre id="gapResponse" class="bg-body-tertiary border rounded p-3 mt-3 mb-0 small" style="min-height: 10rem; white-space: pre-wrap;">Run a gap report to view expected, found, missing, and compact gap ranges.</pre>
            </div>
          </div>

          <div class="card shadow-sm">
            <div class="card-header bg-white">
              <h2 class="h5 mb-0">Recent fetch runs</h2>
            </div>
            <div class="table-responsive">
              <table class="table table-striped table-hover mb-0 align-middle">
                <thead>
                  <tr>
                    <th scope="col">Started</th>
                    <th scope="col">Range</th>
                    <th scope="col">Interval</th>
                    <th scope="col">Status</th>
                    <th scope="col">Inserted</th>
                    <th scope="col">Error</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (fetchRuns.length === 0) { %>
                    <tr>
                      <td colspan="6" class="text-body-secondary">No fetch runs recorded yet.</td>
                    </tr>
                  <% } %>
                  <% fetchRuns.forEach((run) => { %>
                    <tr>
                      <td><%= run.startedAt ? new Date(run.startedAt).toISOString() : '' %></td>
                      <td>
                        <% if (run.rangeFrom && run.rangeTo) { %>
                          <%= new Date(run.rangeFrom).toISOString().slice(0, 10) %> &rarr; <%= new Date(run.rangeTo).toISOString().slice(0, 10) %>
                        <% } else { %>
                          <span class="text-body-secondary">Unknown range</span>
                        <% } %>
                      </td>
                      <td><%= run.interval %> / <%= run.vsCurrency.toUpperCase() %></td>
                      <td>
                        <% if (run.status === 'success') { %>
                          <span class="badge text-bg-success">Success</span>
                        <% } else if (run.status === 'failed') { %>
                          <span class="badge text-bg-danger">Failed</span>
                        <% } else { %>
                          <span class="badge text-bg-secondary"><%= run.status %></span>
                        <% } %>
                      </td>
                      <td><%= run.pointsInserted %></td>
                      <td class="small text-break"><%= run.error || '' %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </section>
      </div>
    </main>

    <script>
      const form = document.getElementById('fetchForm');
      const statusBadge = document.getElementById('fetchStatus');
      const responseBody = document.getElementById('fetchResponse');
      const checkExistingButton = document.getElementById('checkExistingButton');
      const backfillButton = document.getElementById('backfillButton');
      const existingDataSummary = document.getElementById('existingDataSummary');
      const runGapReportButton = document.getElementById('runGapReportButton');
      const gapStatus = document.getElementById('gapStatus');
      const gapSummary = document.getElementById('gapSummary');
      const gapResponse = document.getElementById('gapResponse');
      const assetGapsUrl = '/api/v1/admin/assets/<%= encodeURIComponent(asset.id) %>/gaps';
      const initialRateBudget = <%- JSON.stringify({ safeRemainingCalls: rateBudget.safeRemainingCalls, queueEstimatedCalls: rateBudget.queueEstimatedCalls }) %>;

      function getRangePayload() {
        return {
          from: document.getElementById('from').value,
          to: document.getElementById('to').value,
          interval: document.getElementById('interval').value,
          vsCurrency: document.getElementById('vsCurrency').value
        };
      }

      function getFetchPayload() {
        return {
          ...getRangePayload(),
          conflictPolicy: document.getElementById('conflictPolicy').value
        };
      }

      function buildGapUrl(payload) {
        const params = new URLSearchParams(payload);
        return `${assetGapsUrl}?${params.toString()}`;
      }

      function setBadge(element, ok, text) {
        element.className = `badge ${ok ? 'text-bg-success' : 'text-bg-danger'}`;
        element.textContent = text;
      }

      function renderGapMetric(label, value, tone) {
        return `
          <div class="col-sm-4">
            <div class="border rounded p-3 h-100">
              <div class="text-body-secondary small">${label}</div>
              <div class="fs-4 fw-semibold text-${tone || 'body'}">${value}</div>
            </div>
          </div>
        `;
      }

      function summarizeExistingData(report) {
        if (report.expectedCount === 0) {
          existingDataSummary.className = 'alert alert-warning mt-3 mb-0';
          existingDataSummary.textContent = 'No expected candle buckets were found for this range.';
          return;
        }

        if (report.missingCount === 0) {
          existingDataSummary.className = 'alert alert-success mt-3 mb-0';
          existingDataSummary.textContent = `All ${report.expectedCount} expected ${report.interval} candles already exist locally for ${report.vsCurrency.toUpperCase()}.`;
          return;
        }

        if (report.foundCount > 0) {
          existingDataSummary.className = 'alert alert-warning mt-3 mb-0';
          existingDataSummary.textContent = `${report.foundCount} of ${report.expectedCount} expected ${report.interval} candles already exist locally; ${report.missingCount} are missing.`;
          return;
        }

        existingDataSummary.className = 'alert alert-info mt-3 mb-0';
        existingDataSummary.textContent = `No local candles exist for the ${report.expectedCount} expected ${report.interval} buckets in this range.`;
      }

      function renderGapReport(report) {
        gapSummary.innerHTML = [
          renderGapMetric('Expected', report.expectedCount, 'body'),
          renderGapMetric('Found', report.foundCount, report.foundCount > 0 ? 'success' : 'body'),
          renderGapMetric('Missing', report.missingCount, report.missingCount > 0 ? 'danger' : 'success')
        ].join('');
        gapResponse.textContent = JSON.stringify(report, null, 2);
        summarizeExistingData(report);
      }

      async function runGapReport({ updateGapPanel = true } = {}) {
        const response = await fetch(buildGapUrl(getRangePayload()), {
          headers: { Accept: 'application/json' }
        });
        const data = await response.json();

        if (!response.ok) {
          const message = data.error && data.error.message ? data.error.message : `${response.status} ${response.statusText}`;
          throw new Error(message);
        }

        if (updateGapPanel) {
          setBadge(gapStatus, true, `${response.status} ${response.statusText}`);
          renderGapReport(data.gapReport || data);
        } else {
          summarizeExistingData(data.gapReport || data);
        }

        return data.gapReport || data;
      }

      checkExistingButton.addEventListener('click', async () => {
        existingDataSummary.className = 'alert alert-secondary mt-3 mb-0';
        existingDataSummary.textContent = 'Checking local data...';

        try {
          await runGapReport({ updateGapPanel: false });
        } catch (error) {
          existingDataSummary.className = 'alert alert-danger mt-3 mb-0';
          existingDataSummary.textContent = error.message;
        }
      });

      runGapReportButton.addEventListener('click', async () => {
        gapStatus.className = 'badge text-bg-secondary';
        gapStatus.textContent = 'Running';
        gapResponse.textContent = 'Checking local candle coverage...';

        try {
          await runGapReport();
        } catch (error) {
          gapStatus.className = 'badge text-bg-danger';
          gapStatus.textContent = 'Request failed';
          gapResponse.textContent = error.message;
        }
      });

      async function postJson(url, payload) {
        const response = await fetch(url, {
          method: 'POST',
          headers: {
            Accept: 'application/json',
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(payload)
        });
        const data = await response.json();

        if (!response.ok) {
          const message = data.error && data.error.message ? data.error.message : `${response.status} ${response.statusText}`;
          throw new Error(message);
        }

        return { response, data };
      }

      backfillButton.addEventListener('click', async () => {
        statusBadge.className = 'badge text-bg-secondary';
        statusBadge.textContent = 'Planning backfill';
        responseBody.textContent = 'Detecting missing windows before queueing backfill chunks...';

        try {
          const payload = getFetchPayload();
          const plan = await postJson('/api/v1/admin/assets/<%= encodeURIComponent(asset.id) %>/backfill/plan', payload);
          const projectedCalls = Number(plan.data.projectedCalls || 0);
          const safeRemaining = Number(plan.data.budget ? plan.data.budget.safeRemainingCalls : initialRateBudget.safeRemainingCalls);
          const needsConfirmation = projectedCalls >= 10 || projectedCalls > safeRemaining;

          if (needsConfirmation) {
            const confirmed = window.confirm(`This backfill is estimated to consume ${projectedCalls} CoinGecko call(s). Safe remaining calls this minute: ${safeRemaining}. Continue queueing?`);

            if (!confirmed) {
              statusBadge.className = 'badge text-bg-warning';
              statusBadge.textContent = 'Backfill cancelled';
              responseBody.textContent = JSON.stringify({ cancelled: true, plan: plan.data }, null, 2);
              return;
            }
          }

          const result = await postJson('/api/v1/admin/assets/<%= encodeURIComponent(asset.id) %>/backfill', payload);
          setBadge(statusBadge, true, `${result.response.status} ${result.response.statusText}`);
          responseBody.textContent = JSON.stringify({ plan: plan.data, queued: result.data }, null, 2);
        } catch (error) {
          statusBadge.className = 'badge text-bg-danger';
          statusBadge.textContent = 'Request failed';
          responseBody.textContent = error.message;
        }
      });

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        statusBadge.className = 'badge text-bg-secondary';
        statusBadge.textContent = 'Checking local data';
        responseBody.textContent = 'Checking whether data already exists before fetching...';

        const payload = getFetchPayload();

        try {
          const report = await runGapReport({ updateGapPanel: false });
          const needsConfirmation = initialRateBudget.safeRemainingCalls < 1 || report.missingCount > 1000;

          if (needsConfirmation) {
            const confirmed = window.confirm(`Manual fetch will consume at least 1 CoinGecko call and covers ${report.missingCount} missing candle bucket(s). Safe remaining calls this minute: ${initialRateBudget.safeRemainingCalls}. Continue?`);

            if (!confirmed) {
              statusBadge.className = 'badge text-bg-warning';
              statusBadge.textContent = 'Manual fetch cancelled';
              responseBody.textContent = 'Manual fetch was cancelled before consuming CoinGecko calls.';
              return;
            }
          }

          responseBody.textContent = `Local data check complete: ${report.foundCount} of ${report.expectedCount} expected candles already exist; ${report.missingCount} are missing.\n\nQueueing manual CoinGecko fetch...`;
          statusBadge.textContent = 'Queueing';

          const response = await fetch('/api/v1/admin/assets/<%= encodeURIComponent(asset.id) %>/fetch', {
            method: 'POST',
            headers: {
              Accept: 'application/json',
              'Content-Type': 'application/json'
            },
            body: JSON.stringify(payload)
          });
          const data = await response.json();

          setBadge(statusBadge, response.ok, `${response.status} ${response.statusText}`);
          responseBody.textContent = JSON.stringify(data, null, 2);
        } catch (error) {
          statusBadge.className = 'badge text-bg-danger';
          statusBadge.textContent = 'Request failed';
          responseBody.textContent = error.message;
        }
      });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
