<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/public/css/app.css" rel="stylesheet">
  </head>
  <body>
    <nav class="navbar navbar-expand-lg bg-dark navbar-dark">
      <div class="container">
        <a class="navbar-brand" href="/admin"><%= appName %></a>
        <div class="navbar-nav ms-auto">
          <a class="nav-link" href="/admin/settings">Settings</a>
          <a class="nav-link" href="/admin/assets">Assets</a>
          <a class="nav-link active" href="/admin/config-history">Config History</a>
          <a class="nav-link" href="/admin/reload-status">Reload Status</a>
          <a class="nav-link" href="/admin/backups">Backups</a>
          <%- include('admin-alert-bell') %>
          <a class="nav-link" href="/admin/logs">Logs</a>
          <a class="nav-link" href="/admin/logout">Logout</a>
        </div>
      </div>
    </nav>

    <%- include('admin-maintenance-banner') %>

    <main class="container py-5">
      <div class="d-flex align-items-start justify-content-between flex-wrap gap-3 mb-4">
        <div>
          <h1 class="display-6 fw-bold mb-1">Config History</h1>
          <p class="text-secondary mb-0">Safely edit approved config files, inspect changes, and roll back from recorded backups.</p>
        </div>
        <a href="/admin" class="btn btn-outline-secondary">Back to dashboard</a>
      </div>

      <% if (configAction && configDetails) { %>
        <% const okActions = ['saved', 'rolled back']; %>
        <div class="alert alert-<%= okActions.includes(configAction) ? 'success' : 'danger' %>" role="alert">
          <span class="fw-semibold"><%= configAction %>:</span> <%= configDetails %>
        </div>
      <% } %>

      <section class="card shadow-sm mb-4">
        <div class="card-header bg-white">
          <h2 class="h5 mb-0">Safe JSON editor</h2>
        </div>
        <div class="card-body">
          <p class="text-secondary small">Only <code>config/assets.json</code> and <code>config/server.json</code> can be submitted. Each save validates JSON, backs up the current file, writes atomically, records history, and hot reloads runtime state.</p>
          <div class="accordion" id="configEditorAccordion">
            <% editableConfigs.forEach((editable, index) => { %>
              <div class="accordion-item">
                <h3 class="accordion-header">
                  <button class="accordion-button <%= index === 0 ? '' : 'collapsed' %>" type="button" data-bs-toggle="collapse" data-bs-target="#config-editor-<%= index %>" aria-expanded="<%= index === 0 ? 'true' : 'false' %>" aria-controls="config-editor-<%= index %>">
                    <code><%= editable.filePath %></code>
                  </button>
                </h3>
                <div id="config-editor-<%= index %>" class="accordion-collapse collapse <%= index === 0 ? 'show' : '' %>" data-bs-parent="#configEditorAccordion">
                  <div class="accordion-body">
                    <form method="post" action="/admin/config-history/edit">
                      <input type="hidden" name="filePath" value="<%= editable.filePath %>">
                      <div class="mb-3">
                        <label class="form-label" for="summary-<%= index %>">Summary</label>
                        <input class="form-control" id="summary-<%= index %>" name="summary" maxlength="200" placeholder="Describe the config change" required>
                      </div>
                      <div class="mb-3">
                        <label class="form-label" for="configJson-<%= index %>">New JSON</label>
                        <textarea class="form-control font-monospace" id="configJson-<%= index %>" name="configJson" rows="14" spellcheck="false" required><%= editable.json %></textarea>
                      </div>
                      <button class="btn btn-primary" type="submit">Validate and save <%= editable.filePath %></button>
                    </form>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      </section>

      <div class="row g-4">
        <div class="col-lg-5">
          <section class="card shadow-sm h-100">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
              <h2 class="h5 mb-0">Recent changes</h2>
              <span class="badge text-bg-secondary"><%= changes.length %></span>
            </div>
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead>
                  <tr>
                    <th>Time</th>
                    <th>File</th>
                    <th>Summary</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody>
                  <% if (changes.length === 0) { %>
                    <tr><td colspan="4" class="text-secondary">No config changes have been recorded yet.</td></tr>
                  <% } %>
                  <% changes.forEach((change) => { %>
                    <tr class="<%= selectedId === change.id ? 'table-primary' : '' %>">
                      <td class="small"><%= change.createdAtIso %><div class="text-secondary">#<%= change.id %> by <%= change.changedBy %></div></td>
                      <td><code><%= change.filePath %></code></td>
                      <td><%= change.summary %><div class="small text-secondary text-break"><%= change.backupPath %></div></td>
                      <td><a class="btn btn-sm btn-outline-primary" href="/admin/config-history?change=<%= encodeURIComponent(change.id) %>">Diff</a></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </section>
        </div>

        <div class="col-lg-7">
          <section class="card shadow-sm h-100">
            <div class="card-header bg-white d-flex justify-content-between align-items-center flex-wrap gap-2">
              <h2 class="h5 mb-0">Old / new diff</h2>
              <% if (diff) { %>
                <form method="post" action="/admin/config-history/<%= encodeURIComponent(diff.change.id) %>/rollback" onsubmit="return confirm('Rollback <%= diff.change.filePath %> to backup <%= diff.change.backupPath %>?');">
                  <button class="btn btn-sm btn-danger" type="submit">Rollback to old config</button>
                </form>
              <% } %>
            </div>
            <div class="card-body">
              <% if (!diff) { %>
                <p class="text-secondary mb-0">Select a change to view its diff and rollback action.</p>
              <% } else { %>
                <dl class="row small">
                  <dt class="col-sm-2">File</dt>
                  <dd class="col-sm-10"><code><%= diff.change.filePath %></code></dd>
                  <dt class="col-sm-2">Old</dt>
                  <dd class="col-sm-10 text-break"><code><%= diff.oldLabel %></code></dd>
                  <dt class="col-sm-2">New</dt>
                  <dd class="col-sm-10 text-break"><code><%= diff.newLabel %></code></dd>
                </dl>
                <pre class="border rounded bg-body-tertiary p-3 overflow-auto" style="max-height: 48rem;"><% diff.lines.forEach((line) => { %><span class="<%= line.type === 'added' ? 'text-success' : (line.type === 'removed' ? 'text-danger' : 'text-secondary') %>"><%= line.type === 'added' ? '+' : (line.type === 'removed' ? '-' : ' ') %> <%= line.text %></span>
<% }) %></pre>
              <% } %>
            </div>
          </section>
        </div>
      </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
