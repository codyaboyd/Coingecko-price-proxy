<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/public/css/app.css" rel="stylesheet">
  </head>
  <body>
    <nav class="navbar navbar-expand-lg bg-dark navbar-dark">
      <div class="container">
        <a class="navbar-brand" href="/admin"><%= appName %></a>
        <div class="navbar-nav ms-auto">
          <a class="nav-link" href="/admin/assets">Assets</a>
          <a class="nav-link active" href="/admin/rate-budget">Rate Budget</a>
          <a class="nav-link" href="/admin/system-health">System Health</a>
          <a class="nav-link" href="/admin/db-integrity">DB Integrity</a>
          <a class="nav-link" href="/admin/logout">Logout</a>
        </div>
      </div>
    </nav>

    <%- include('admin-maintenance-banner') %>

    <main class="container py-5">
      <div class="d-flex align-items-start justify-content-between flex-wrap gap-3 mb-4">
        <div>
          <h1 class="display-6 fw-bold mb-1">CoinGecko rate-limit budget</h1>
          <p class="text-body-secondary mb-0">Conservative planner: failed CoinGecko requests are counted because CoinGecko counts them against the limit too.</p>
        </div>
        <% if (budget.safeMode) { %>
          <span class="badge text-bg-warning fs-6">Safe mode on</span>
        <% } else { %>
          <span class="badge text-bg-secondary fs-6">Safe mode off</span>
        <% } %>
      </div>

      <% if (budget.responses429 > 0) { %>
        <div class="alert alert-warning" role="alert">
          <strong>429 responses detected.</strong>
          Safe mode reduces the effective limit to 50% after a 429 and slowly recovers over time.
          <% if (budget.recoveryUntilIso) { %>Current recovery target: <%= budget.recoveryUntilIso %>.<% } %>
        </div>
      <% } %>

      <div class="row g-3 mb-4">
        <div class="col-sm-6 col-xl-3"><div class="card shadow-sm h-100"><div class="card-body"><p class="text-uppercase text-secondary small fw-semibold mb-1">Configured max/min</p><p class="display-6 mb-0"><%= budget.configuredMaxCallsPerMinute %></p><p class="small text-secondary mb-0">Effective: <%= budget.effectiveMaxCallsPerMinute %></p></div></div></div>
        <div class="col-sm-6 col-xl-3"><div class="card shadow-sm h-100"><div class="card-body"><p class="text-uppercase text-secondary small fw-semibold mb-1">Current calls used</p><p class="display-6 mb-0"><%= budget.currentCallsUsed %></p><p class="small text-secondary mb-0">This rolling minute</p></div></div></div>
        <div class="col-sm-6 col-xl-3"><div class="card shadow-sm h-100"><div class="card-body"><p class="text-uppercase text-secondary small fw-semibold mb-1">Safe remaining</p><p class="display-6 mb-0"><%= budget.safeRemainingCalls %></p><p class="small text-secondary mb-0">Reserve: <%= budget.reserveCalls %> calls</p></div></div></div>
        <div class="col-sm-6 col-xl-3"><div class="card shadow-sm h-100"><div class="card-body"><p class="text-uppercase text-secondary small fw-semibold mb-1">Queue estimated calls</p><p class="display-6 mb-0"><%= budget.queueEstimatedCalls %></p><p class="small text-secondary mb-0">Drain: <%= budget.estimatedTimeToDrainQueueMinutes %> min</p></div></div></div>
      </div>

      <div class="row g-4">
        <section class="col-lg-5">
          <div class="card shadow-sm h-100">
            <div class="card-header bg-white"><h2 class="h5 mb-0">Observed call counters</h2></div>
            <div class="card-body">
              <dl class="row mb-0">
                <dt class="col-7">Calls this minute</dt><dd class="col-5"><%= budget.callsThisMinute %></dd>
                <dt class="col-7">Successful calls</dt><dd class="col-5"><%= budget.successfulCalls %></dd>
                <dt class="col-7">Failed calls</dt><dd class="col-5"><%= budget.failedCalls %></dd>
                <dt class="col-7">429 responses</dt><dd class="col-5"><%= budget.responses429 %></dd>
                <dt class="col-7">Avg calls / asset refresh</dt><dd class="col-5"><%= budget.averageCallsPerAssetRefresh.toFixed(2) %></dd>
                <dt class="col-7">Last 429</dt><dd class="col-5"><%= budget.last429AtIso || 'none' %></dd>
              </dl>
            </div>
          </div>
        </section>

        <section class="col-lg-7">
          <div class="card shadow-sm h-100">
            <div class="card-header bg-white"><h2 class="h5 mb-0">Assets expensive to backfill</h2></div>
            <div class="table-responsive">
              <table class="table table-striped align-middle mb-0">
                <thead><tr><th>Asset</th><th>Queued jobs</th><th>Projected calls</th><th>Backfill policy</th></tr></thead>
                <tbody>
                  <% if (budget.expensiveAssets.length === 0) { %>
                    <tr><td colspan="4" class="text-body-secondary">No expensive queued or configured backfills detected.</td></tr>
                  <% } %>
                  <% budget.expensiveAssets.forEach((asset) => { %>
                    <tr>
                      <td><a href="/admin/assets/<%= encodeURIComponent(asset.id) %>"><%= asset.symbol %></a><div class="small text-secondary"><%= asset.name %></div></td>
                      <td><%= asset.queuedJobs %></td>
                      <td><%= asset.projectedCalls %></td>
                      <td class="small">Daily: <%= asset.dailyBackfill ? 'yes' : 'no' %>; max days/run: <%= asset.maxBackfillDaysPerRun || 'default' %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </section>
      </div>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
