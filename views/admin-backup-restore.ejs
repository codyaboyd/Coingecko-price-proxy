<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/public/css/app.css" rel="stylesheet">
  </head>
  <body>
    <nav class="navbar navbar-expand-lg bg-dark navbar-dark">
      <div class="container">
        <a class="navbar-brand" href="/admin"><%= appName %></a>
        <div class="navbar-nav ms-auto">
          <a class="nav-link" href="/admin/assets">Assets</a>
          <a class="nav-link" href="/admin/imports">Imports</a>
          <a class="nav-link active" aria-current="page" href="/admin/backups">Backups</a>
          <a class="nav-link" href="/admin/reload-status">Reload Status</a>
          <a class="nav-link" href="/admin/system-health">System Health</a>
          <a class="nav-link" href="/admin/api-test">API Test</a>
          <a class="nav-link" href="/admin/logout">Logout</a>
        </div>
      </div>
    </nav>

    <main class="container py-5">
      <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
        <div>
          <h1 class="display-6 fw-bold mb-2">Restore SQLite backup</h1>
          <p class="lead mb-0">Restore a backup from <code>data/backups/</code> after validation and an emergency backup.</p>
          <p class="text-danger mb-0">This replaces the live database. Active jobs must finish before restore starts.</p>
        </div>
        <a class="btn btn-outline-secondary" href="/admin/backups">Back to backups</a>
      </div>

      <% if (backupAction) { %>
        <div class="alert <%= backupAction === 'restored' ? 'alert-success' : 'alert-danger' %> alert-dismissible fade show" role="alert">
          Backup action: <strong><%= backupAction %></strong><% if (backupDetails) { %> — <%= backupDetails %><% } %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% } %>

      <div class="row g-4">
        <div class="col-lg-7">
          <div class="card shadow-sm">
            <div class="card-header bg-white">
              <h2 class="h5 mb-1">Restore confirmation</h2>
              <p class="small text-secondary mb-0">Select a backup and type its exact filename or <code><%= confirmationPhrase %></code>.</p>
            </div>
            <div class="card-body">
              <% if (backups.length === 0) { %>
                <div class="alert alert-warning mb-0">No backups are available to restore.</div>
              <% } else { %>
                <form method="post" action="/admin/backups/restore" onsubmit="return confirm('Restore the selected backup and replace the live database?');">
                  <div class="mb-3">
                    <label for="backupFile" class="form-label">Backup file</label>
                    <select class="form-select" id="backupFile" name="backupFile" required>
                      <% backups.forEach((backup) => { %>
                        <option value="<%= backup.fileName %>" <%= backup.fileName === selectedFile ? 'selected' : '' %>><%= backup.fileName %> — <%= backup.createdAtIso || 'unknown date' %> — <%= backup.sizeLabel %></option>
                      <% }) %>
                    </select>
                  </div>
                  <div class="mb-3">
                    <label for="confirmation" class="form-label">Type the backup filename or confirmation phrase</label>
                    <input class="form-control" id="confirmation" name="confirmation" autocomplete="off" required placeholder="history-YYYY-MM-DD-HH-mm-ss.sqlite">
                    <div class="form-text">Alternative phrase: <code><%= confirmationPhrase %></code></div>
                  </div>
                  <button type="submit" class="btn btn-danger">Validate and restore backup</button>
                </form>
              <% } %>
            </div>
          </div>
        </div>

        <div class="col-lg-5">
          <div class="card border-warning shadow-sm">
            <div class="card-header bg-warning-subtle">
              <h2 class="h5 mb-0">Safety workflow</h2>
            </div>
            <div class="card-body">
              <ol class="mb-3">
                <li>Stop scheduler timers and queued jobs.</li>
                <li>Create an emergency copy of the current SQLite database.</li>
                <li>Validate the selected file is SQLite and contains expected tables.</li>
                <li>Move the current database files into <code>data/backups/emergency/</code>.</li>
                <li>Copy the selected backup to the configured database path.</li>
                <li>Run migrations and restart in-memory asset and scheduler state.</li>
              </ol>
              <p class="small text-secondary mb-0">Every restore attempt is logged in <code>data/backups/restore-attempts.log</code>.</p>
            </div>
          </div>
        </div>
      </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
