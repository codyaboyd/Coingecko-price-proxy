<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/public/css/app.css" rel="stylesheet">
  </head>
  <body>
    <nav class="navbar navbar-expand-lg bg-dark navbar-dark">
      <div class="container">
        <a class="navbar-brand" href="/admin"><%= appName %></a>
        <div class="navbar-nav ms-auto">
          <a class="nav-link" href="/admin/assets">Assets</a>
          <a class="nav-link" href="/admin/imports">Imports</a>
          <a class="nav-link" href="/admin/backups">Backups</a>
          <a class="nav-link active" href="/admin/doctor">Doctor</a>
          <a class="nav-link" href="/admin/system-health">System Health</a>
          <a class="nav-link" href="/admin/logout">Logout</a>
        </div>
      </div>
    </nav>

    <%- include('admin-maintenance-banner') %>

    <% const badgeClass = (severity) => severity === 'ok' ? 'text-bg-success' : (severity === 'info' ? 'text-bg-info' : (severity === 'warning' ? 'text-bg-warning' : 'text-bg-danger')); %>
    <% const cardClass = (severity) => severity === 'ok' ? 'border-success' : (severity === 'info' ? 'border-info' : (severity === 'warning' ? 'border-warning' : 'border-danger')); %>
    <% const alertClass = (severity) => severity === 'ok' ? 'alert-success' : (severity === 'info' ? 'alert-info' : (severity === 'warning' ? 'alert-warning' : 'alert-danger')); %>

    <main class="container py-4 py-md-5">
      <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
        <div>
          <h1 class="display-6 fw-bold mb-1">Admin Doctor</h1>
          <p class="lead text-body-secondary mb-0">One-click solo maintenance checks and safe automatic repairs.</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
          <a class="btn btn-primary" href="/admin/doctor">Run doctor</a>
          <a class="btn btn-outline-secondary" href="/admin">Back to dashboard</a>
        </div>
      </div>

      <% if (doctorAction) { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
          <strong>Fix complete:</strong> <%= doctorAction %><% if (doctorDetails) { %> — <%= doctorDetails %><% } %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% } %>

      <div class="card shadow-sm mb-4 border-0">
        <div class="card-body">
          <div class="row g-3 align-items-center">
            <div class="col-md-3">
              <p class="text-uppercase text-secondary small fw-semibold mb-1">Overall</p>
              <span class="badge fs-6 <%= badgeClass(report.status) %>"><%= report.status %></span>
            </div>
            <div class="col-md-3">
              <p class="text-uppercase text-secondary small fw-semibold mb-1">Generated</p>
              <p class="mb-0"><code><%= report.generatedAtIso %></code></p>
            </div>
            <div class="col-md-6">
              <p class="text-uppercase text-secondary small fw-semibold mb-1">Housekeeping</p>
              <div class="d-flex flex-wrap gap-2">
                <% report.cleanupFixes.forEach((fix) => { %>
                  <form method="post" action="/admin/doctor/fix" class="doctor-fix-form m-0">
                    <input type="hidden" name="action" value="<%= fix.action %>">
                    <button type="submit" class="btn btn-outline-primary btn-sm"><%= fix.label %></button>
                  </form>
                <% }) %>
              </div>
            </div>
          </div>
          <div class="row g-3 mt-2">
            <div class="col-3"><div class="p-3 rounded bg-success-subtle text-center"><div class="h3 mb-0"><%= report.summary.ok %></div><div class="small text-uppercase fw-semibold">OK</div></div></div>
            <div class="col-3"><div class="p-3 rounded bg-info-subtle text-center"><div class="h3 mb-0"><%= report.summary.info %></div><div class="small text-uppercase fw-semibold">Info</div></div></div>
            <div class="col-3"><div class="p-3 rounded bg-warning-subtle text-center"><div class="h3 mb-0"><%= report.summary.warning %></div><div class="small text-uppercase fw-semibold">Warning</div></div></div>
            <div class="col-3"><div class="p-3 rounded bg-danger-subtle text-center"><div class="h3 mb-0"><%= report.summary.critical %></div><div class="small text-uppercase fw-semibold">Critical</div></div></div>
          </div>
        </div>
      </div>

      <div class="alert <%= alertClass(report.status) %> shadow-sm" role="alert">
        <strong>Doctor result:</strong>
        <% if (report.status === 'ok') { %>
          No issues need attention. You can still run safe housekeeping fixes when needed.
        <% } else if (report.status === 'info') { %>
          Informational maintenance items were found; review them at your convenience.
        <% } else { %>
          Issues were found. Start with critical cards, create a backup before repairs, and use safe automatic fixes where available.
        <% } %>
      </div>

      <div class="row g-4">
        <% report.issues.forEach((issue, index) => { %>
          <div class="col-lg-6">
            <div class="card shadow-sm h-100 <%= cardClass(issue.severity) %>">
              <div class="card-header bg-white d-flex justify-content-between align-items-start gap-3">
                <div>
                  <h2 class="h5 mb-1"><%= issue.label %></h2>
                  <p class="small text-secondary mb-0"><code><%= issue.id %></code></p>
                </div>
                <span class="badge <%= badgeClass(issue.severity) %>"><%= issue.severity %></span>
              </div>
              <div class="card-body">
                <div class="alert <%= alertClass(issue.severity) %> py-2" role="alert">
                  <strong>Explanation:</strong> <%= issue.explanation %>
                </div>
                <p class="mb-3"><strong>Recommended action:</strong> <%= issue.recommendedAction %></p>

                <% if (issue.safeFixes.length > 0 || issue.dangerousFixes.length > 0) { %>
                  <div class="d-flex flex-wrap gap-2 mb-3">
                    <% issue.safeFixes.forEach((fix) => { %>
                      <form method="post" action="/admin/doctor/fix" class="doctor-fix-form m-0">
                        <input type="hidden" name="action" value="<%= fix.action %>">
                        <button type="submit" class="btn btn-primary btn-sm"><%= fix.label %></button>
                      </form>
                    <% }) %>
                    <% issue.dangerousFixes.forEach((fix) => { %>
                      <form method="post" action="/admin/doctor/fix" class="doctor-fix-form doctor-dangerous-form m-0" data-confirm-phrase="<%= fix.confirmationPhrase %>">
                        <input type="hidden" name="action" value="<%= fix.action %>">
                        <button type="submit" class="btn btn-danger btn-sm"><%= fix.label %></button>
                      </form>
                    <% }) %>
                  </div>
                <% } else { %>
                  <p class="text-secondary small mb-3">No automatic fix is available for this check.</p>
                <% } %>

                <% if (issue.details && ((Array.isArray(issue.details) && issue.details.length > 0) || (!Array.isArray(issue.details) && typeof issue.details === 'object'))) { %>
                  <button class="btn btn-outline-secondary btn-sm" type="button" data-bs-toggle="collapse" data-bs-target="#doctor-details-<%= index %>" aria-expanded="false" aria-controls="doctor-details-<%= index %>">Show details</button>
                  <div class="collapse mt-3" id="doctor-details-<%= index %>">
                    <pre class="bg-body-tertiary border rounded p-3 small mb-0"><code><%- JSON.stringify(issue.details, null, 2) %></code></pre>
                  </div>
                <% } %>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      document.querySelectorAll('.doctor-dangerous-form').forEach(function attachTypedConfirmation(form) {
        form.addEventListener('submit', function confirmDangerousFix(event) {
          var phrase = form.getAttribute('data-confirm-phrase') || 'CONFIRM';
          var typed = window.prompt('This repair is dangerous. Type "' + phrase + '" to continue.');
          if (typed !== phrase) {
            event.preventDefault();
          }
        });
      });
    </script>
  </body>
</html>
