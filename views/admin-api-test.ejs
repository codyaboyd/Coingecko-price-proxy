<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/public/css/app.css" rel="stylesheet">
  </head>
  <body>
    <nav class="navbar navbar-expand-lg bg-dark navbar-dark">
      <div class="container">
        <a class="navbar-brand" href="/admin"><%= appName %></a>
        <div class="navbar-nav">
          <a class="nav-link" href="/admin">Admin</a>
          <a class="nav-link" href="/admin/assets">Assets</a>
          <a class="nav-link" href="/admin/system-health">System Health</a>
          <a class="nav-link" href="/admin/db-integrity">DB Integrity</a>
          <a class="nav-link" href="/admin/rate-budget">Rate Budget</a>
          <a class="nav-link active" aria-current="page" href="/admin/api-test">API Test</a>
          <%- include('admin-alert-bell') %>
          <a class="nav-link" href="/admin/logout">Logout</a>
        </div>
      </div>
    </nav>

    <%- include('admin-maintenance-banner') %>

    <main class="container py-5">
      <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 mb-4">
        <div>
          <h1 class="display-6 fw-bold mb-1">Local history API test</h1>
          <p class="text-body-secondary mb-0">Build requests for <code>GET /api/v1/history/:assetId</code> without calling CoinGecko.</p>
        </div>
        <a class="btn btn-outline-secondary align-self-start" href="/admin">Back to admin</a>
      </div>

      <div class="row g-4">
        <section class="col-lg-5">
          <div class="card shadow-sm">
            <div class="card-header bg-white">
              <h2 class="h5 mb-0">Request options</h2>
            </div>
            <div class="card-body">
              <form id="historyTestForm" class="vstack gap-3">
                <div>
                  <label for="assetId" class="form-label">Asset</label>
                  <select id="assetId" class="form-select" required>
                    <% assets.forEach((asset) => { %>
                      <option value="<%= asset.id %>" data-vs="<%= asset.vsCurrency %>"><%= asset.symbol %> — <%= asset.name %></option>
                    <% }) %>
                  </select>
                </div>

                <div class="row g-3">
                  <div class="col-sm-6">
                    <label for="from" class="form-label">From</label>
                    <input id="from" type="date" class="form-control">
                  </div>
                  <div class="col-sm-6">
                    <label for="to" class="form-label">To</label>
                    <input id="to" type="date" class="form-control">
                  </div>
                </div>

                <div class="row g-3">
                  <div class="col-sm-6">
                    <label for="interval" class="form-label">Interval</label>
                    <select id="interval" class="form-select">
                      <option value="1d" selected>1 day</option>
                      <option value="1h">1 hour</option>
                      <option value="5m">5 minutes</option>
                    </select>
                  </div>
                  <div class="col-sm-6">
                    <label for="format" class="form-label">Format</label>
                    <select id="format" class="form-select">
                      <option value="json" selected>JSON</option>
                      <option value="csv">CSV</option>
                    </select>
                  </div>
                </div>

                <div class="row g-3">
                  <div class="col-sm-6">
                    <label for="vs" class="form-label">Currency</label>
                    <input id="vs" class="form-control" placeholder="Asset default">
                  </div>
                  <div class="col-sm-6">
                    <label for="limit" class="form-label">Limit</label>
                    <input id="limit" type="number" class="form-control" min="1" max="5000" placeholder="1000">
                  </div>
                </div>

                <div>
                  <label for="fill" class="form-label">Fill</label>
                  <select id="fill" class="form-select">
                    <option value="none" selected>None</option>
                    <option value="previous">Previous candle</option>
                  </select>
                </div>

                <button type="submit" class="btn btn-primary">Run request</button>
              </form>
            </div>
          </div>
        </section>

        <section class="col-lg-7">
          <div class="card shadow-sm mb-4">
            <div class="card-header bg-white">
              <h2 class="h5 mb-0">Generated URL</h2>
            </div>
            <div class="card-body">
              <a id="requestUrl" href="/api/v1/history/<%= assets[0] ? assets[0].id : '' %>" class="text-break">/api/v1/history/<%= assets[0] ? assets[0].id : '' %></a>
            </div>
          </div>

          <div class="card shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
              <h2 class="h5 mb-0">Response</h2>
              <span id="responseMeta" class="badge text-bg-secondary">Not run</span>
            </div>
            <div class="card-body">
              <pre id="responseBody" class="bg-body-tertiary border rounded p-3 mb-0 small" style="min-height: 20rem; white-space: pre-wrap;">Submit the form to call the local API.</pre>
            </div>
          </div>
        </section>
      </div>
    </main>

    <script>
      const form = document.getElementById('historyTestForm');
      const requestUrl = document.getElementById('requestUrl');
      const responseBody = document.getElementById('responseBody');
      const responseMeta = document.getElementById('responseMeta');
      const assetSelect = document.getElementById('assetId');
      const vsInput = document.getElementById('vs');

      function buildUrl() {
        const params = new URLSearchParams();
        const assetId = assetSelect.value;
        const fields = ['from', 'to', 'interval', 'format', 'vs', 'limit', 'fill'];

        fields.forEach((field) => {
          const value = document.getElementById(field).value.trim();

          if (value) {
            params.set(field, value);
          }
        });

        params.set('source', 'local');

        const query = params.toString();
        return `/api/v1/history/${encodeURIComponent(assetId)}${query ? `?${query}` : ''}`;
      }

      function updateUrl() {
        const url = buildUrl();
        requestUrl.href = url;
        requestUrl.textContent = url;
      }

      assetSelect.addEventListener('change', () => {
        vsInput.placeholder = assetSelect.selectedOptions[0].dataset.vs || 'Asset default';
        updateUrl();
      });

      form.addEventListener('input', updateUrl);
      form.addEventListener('change', updateUrl);

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        updateUrl();
        responseMeta.className = 'badge text-bg-secondary';
        responseMeta.textContent = 'Loading';
        responseBody.textContent = 'Loading...';

        try {
          const response = await fetch(requestUrl.href, { headers: { Accept: '*/*' } });
          const text = await response.text();
          const contentType = response.headers.get('content-type') || '';

          responseMeta.className = `badge ${response.ok ? 'text-bg-success' : 'text-bg-danger'}`;
          responseMeta.textContent = `${response.status} ${response.statusText}`;

          if (contentType.includes('application/json')) {
            responseBody.textContent = JSON.stringify(JSON.parse(text), null, 2);
          } else {
            responseBody.textContent = text;
          }
        } catch (error) {
          responseMeta.className = 'badge text-bg-danger';
          responseMeta.textContent = 'Request failed';
          responseBody.textContent = error.message;
        }
      });

      const selectedAsset = new URLSearchParams(window.location.search).get('asset');

      if (selectedAsset) {
        const matchingOption = Array.from(assetSelect.options).find((option) => option.value === selectedAsset);

        if (matchingOption) {
          assetSelect.value = selectedAsset;
        }
      }

      vsInput.placeholder = assetSelect.selectedOptions[0] ? assetSelect.selectedOptions[0].dataset.vs : 'Asset default';
      updateUrl();
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
