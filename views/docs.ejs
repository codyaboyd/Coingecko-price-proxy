<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/public/css/app.css" rel="stylesheet">
  </head>
  <body class="bg-body-tertiary">
    <nav class="navbar navbar-expand-lg bg-dark navbar-dark">
      <div class="container">
        <a class="navbar-brand" href="/docs">Chrono Cache API Docs</a>
        <div class="navbar-nav ms-auto">
          <a class="nav-link" href="/api/v1/openapi.json">OpenAPI JSON</a>
          <a class="nav-link" href="/admin">Admin</a>
        </div>
      </div>
    </nav>

    <main class="container py-5">
      <section class="p-4 p-md-5 mb-4 rounded bg-white shadow-sm">
        <div class="row g-4 align-items-center">
          <div class="col-lg-8">
            <p class="text-uppercase text-secondary small fw-semibold mb-2">Self-documenting local API</p>
            <h1 class="display-6 fw-bold mb-3"><%= title %></h1>
            <p class="lead mb-0">Use these offline-friendly docs to inspect the local cache API, copy curl commands, and run live examples against the server you are viewing now.</p>
          </div>
          <div class="col-lg-4">
            <div class="card border-primary-subtle">
              <div class="card-body">
                <h2 class="h6 text-uppercase text-secondary">Current assets</h2>
                <p class="display-6 mb-1"><%= assets.length %></p>
                <p class="small text-secondary mb-0">Examples default to <code><%= selectedAsset.id %></code>. Choose another asset in the live examples section.</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="row g-4 mb-4" aria-labelledby="quick-start-heading">
        <div class="col-lg-7">
          <div class="card shadow-sm h-100">
            <div class="card-header bg-white">
              <h2 id="quick-start-heading" class="h5 mb-0">Quick start</h2>
            </div>
            <div class="card-body">
              <p>All public endpoints are under <code>/api/v1</code> and read from local SQLite cache data. History responses support JSON by default and CSV with <code>format=csv</code>.</p>
              <ul class="mb-0">
                <li>Supported intervals: <code>5m</code>, <code>1h</code>, <code>1d</code>.</li>
                <li>Date filters accept ISO dates, ISO timestamps, or millisecond timestamps.</li>
                <li>Use <code>fill=previous</code> to fill missing candles from the previous close.</li>
                <li>Use <code>cache=bypass</code> when you need to skip the local response cache.</li>
              </ul>
            </div>
          </div>
        </div>
        <div class="col-lg-5">
          <div class="card shadow-sm h-100">
            <div class="card-header bg-white">
              <h2 class="h5 mb-0">Generated OpenAPI-style JSON</h2>
            </div>
            <div class="card-body">
              <p>The machine-readable document is generated from the current configured assets.</p>
              <div class="d-flex gap-2 flex-wrap">
                <a class="btn btn-primary" href="<%= openApiUrl %>">Open <%= openApiUrl %></a>
                <button class="btn btn-outline-secondary copy-btn" type="button" data-copy="curl http://127.0.0.1:3000<%= openApiUrl %>">Copy curl</button>
              </div>
            </div>
          </div>
        </div>
      </section>


      <section class="card shadow-sm mb-4" aria-labelledby="price-query-heading">
        <div class="card-header bg-white">
          <h2 id="price-query-heading" class="h4 mb-1">How to query prices</h2>
          <p class="small text-secondary mb-0">Price endpoints return cached local OHLCV candles; they do not call CoinGecko while handling your request.</p>
        </div>
        <div class="card-body">
          <div class="row g-4">
            <div class="col-lg-6">
              <h3 class="h6">1. Discover asset IDs</h3>
              <p class="small text-secondary">Start with <code>GET /api/v1/assets</code> to find enabled asset IDs, default quote currencies, and cached range hints.</p>
              <div class="position-relative mb-3">
                <pre class="bg-dark text-white rounded p-3 pe-5 mb-0"><code>curl http://127.0.0.1:3000/api/v1/assets</code></pre>
                <button class="btn btn-sm btn-light position-absolute top-0 end-0 m-2 copy-btn" type="button" data-copy="curl http://127.0.0.1:3000/api/v1/assets">Copy</button>
              </div>
              <h3 class="h6">2. Request candles</h3>
              <p class="small text-secondary mb-2">Use <code>GET /api/v1/history/:assetId</code>. The latest spot-like value for most integrations is the last candle's <code>close</code>.</p>
              <div class="position-relative">
                <pre class="bg-dark text-white rounded p-3 pe-5 mb-0"><code>curl 'http://127.0.0.1:3000/api/v1/history/<%= encodeURIComponent(selectedAsset.id) %>?interval=1d&amp;vs=<%= encodeURIComponent(selectedAsset.vsCurrency) %>&amp;limit=5'</code></pre>
                <button class="btn btn-sm btn-light position-absolute top-0 end-0 m-2 copy-btn" type="button" data-copy="curl 'http://127.0.0.1:3000/api/v1/history/<%= encodeURIComponent(selectedAsset.id) %>?interval=1d&amp;vs=<%= encodeURIComponent(selectedAsset.vsCurrency) %>&amp;limit=5'">Copy</button>
              </div>
            </div>
            <div class="col-lg-6">
              <h3 class="h6">History query parameters</h3>
              <div class="table-responsive">
                <table class="table table-sm align-middle mb-3">
                  <thead>
                    <tr><th>Parameter</th><th>Default</th><th>Use</th></tr>
                  </thead>
                  <tbody>
                    <tr><td><code>interval</code></td><td><code>1d</code></td><td><code>5m</code>, <code>1h</code>, or <code>1d</code>.</td></tr>
                    <tr><td><code>from</code> / <code>to</code></td><td>cached range</td><td>ISO date, ISO timestamp, or millisecond timestamp.</td></tr>
                    <tr><td><code>vs</code></td><td>asset default</td><td>Quote currency, such as <code>usd</code>.</td></tr>
                    <tr><td><code>limit</code></td><td><code>1000</code></td><td>Return <code>1</code> to <code>5000</code> candles.</td></tr>
                    <tr><td><code>format</code></td><td><code>json</code></td><td>Use <code>csv</code> for comma-separated output.</td></tr>
                    <tr><td><code>fill</code></td><td><code>none</code></td><td>Use <code>previous</code> to fill gaps from the previous close.</td></tr>
                    <tr><td><code>cache</code></td><td>enabled</td><td>Use <code>bypass</code> to skip the local API response cache.</td></tr>
                  </tbody>
                </table>
              </div>
              <p class="small text-secondary mb-0">Range limits protect large reads: <code>5m</code> allows 31 days, <code>1h</code> allows two leap years, and <code>1d</code> allows 20 leap years.</p>
            </div>
          </div>
        </div>
      </section>

      <section class="card shadow-sm mb-4" aria-labelledby="assets-heading">
        <div class="card-header bg-white d-flex justify-content-between align-items-center flex-wrap gap-2">
          <div>
            <h2 id="assets-heading" class="h5 mb-1">Assets used by examples</h2>
            <p class="small text-secondary mb-0">These are the enabled assets returned by <code>GET /api/v1/assets</code>.</p>
          </div>
        </div>
        <div class="table-responsive">
          <table class="table table-sm align-middle mb-0">
            <thead>
              <tr><th>ID</th><th>Symbol</th><th>Name</th><th>vs</th><th>Range hint</th></tr>
            </thead>
            <tbody>
              <% assets.forEach((asset) => { %>
                <tr>
                  <td><code><%= asset.id %></code></td>
                  <td><%= asset.symbol %></td>
                  <td><%= asset.name %></td>
                  <td><code><%= asset.vsCurrency %></code></td>
                  <td class="small text-secondary">
                    <% if (asset.earliestTs || asset.latestTs) { %>
                      <%= asset.earliestTs ? new Date(asset.earliestTs).toISOString() : 'unknown' %> → <%= asset.latestTs ? new Date(asset.latestTs).toISOString() : 'unknown' %>
                    <% } else { %>
                      No cached candle range advertised yet.
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>

      <section aria-labelledby="endpoints-heading">
        <h2 id="endpoints-heading" class="h4 mb-3">Public endpoints</h2>
        <div class="vstack gap-3 mb-4">
          <% publicEndpoints.forEach((endpoint) => { %>
            <article class="card shadow-sm">
              <div class="card-header bg-white d-flex align-items-center gap-2 flex-wrap">
                <span class="badge text-bg-success"><%= endpoint.method %></span>
                <code><%= endpoint.path %></code>
              </div>
              <div class="card-body">
                <p><%= endpoint.description %></p>
                <h3 class="h6">curl</h3>
                <div class="position-relative mb-3">
                  <pre class="bg-dark text-white rounded p-3 pe-5 mb-0"><code><%= endpoint.curl %></code></pre>
                  <button class="btn btn-sm btn-light position-absolute top-0 end-0 m-2 copy-btn" type="button" data-copy="<%= endpoint.curl %>">Copy</button>
                </div>
                <h3 class="h6">Response example</h3>
                <pre class="bg-body-secondary rounded p-3 mb-0"><code><%- JSON.stringify(endpoint.response, null, 2) %></code></pre>
              </div>
            </article>
          <% }) %>
        </div>
      </section>

      <section class="card shadow-sm mb-4" aria-labelledby="live-heading">
        <div class="card-header bg-white">
          <h2 id="live-heading" class="h4 mb-1">Live examples</h2>
          <p class="small text-secondary mb-0">These buttons fetch from this server using plain JavaScript and the selected current asset.</p>
        </div>
        <div class="card-body">
          <div class="row g-3 align-items-end mb-3">
            <div class="col-md-4">
              <label class="form-label" for="assetSelect">Asset</label>
              <select id="assetSelect" class="form-select">
                <% assets.forEach((asset) => { %>
                  <option value="<%= asset.id %>" data-vs="<%= asset.vsCurrency %>"><%= asset.symbol %> — <%= asset.name %> (<%= asset.id %>)</option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-3">
              <label class="form-label" for="intervalSelect">Interval</label>
              <select id="intervalSelect" class="form-select">
                <option value="1d">1d</option>
                <option value="1h">1h</option>
                <option value="5m">5m</option>
              </select>
            </div>
            <div class="col-md-2">
              <label class="form-label" for="limitInput">Limit</label>
              <input id="limitInput" class="form-control" type="number" min="1" max="5000" value="5">
            </div>
            <div class="col-md-3 d-flex gap-2 flex-wrap">
              <button class="btn btn-primary live-btn" type="button" data-kind="assets">List assets</button>
              <button class="btn btn-outline-primary live-btn" type="button" data-kind="asset">Get asset</button>
              <button class="btn btn-outline-primary live-btn" type="button" data-kind="history">Get history</button>
            </div>
          </div>
          <p class="small mb-2">Request: <a id="liveUrl" href="/api/v1/assets" class="text-break">/api/v1/assets</a></p>
          <pre class="bg-dark text-white rounded p-3 mb-0"><code id="liveOutput">Click a live example to fetch data from this local server.</code></pre>
        </div>
      </section>

      <section class="card shadow-sm" aria-labelledby="admin-heading">
        <div class="card-header bg-white">
          <h2 id="admin-heading" class="h4 mb-1">Admin endpoints summary</h2>
          <p class="small text-secondary mb-0">Admin JSON endpoints are session-protected and live below <code>/api/v1/admin</code>.</p>
        </div>
        <div class="card-body">
          <ul class="mb-0">
            <% adminEndpoints.forEach((endpoint) => { %>
              <li><code><%= endpoint %></code></li>
            <% }) %>
          </ul>
        </div>
      </section>
    </main>

    <script>
      function writeClipboard(text, button) {
        const original = button.textContent;
        const done = function () {
          button.textContent = 'Copied';
          setTimeout(function () { button.textContent = original; }, 1200);
        };

        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(done).catch(function () {
            fallbackCopy(text);
            done();
          });
          return;
        }

        fallbackCopy(text);
        done();
      }

      function fallbackCopy(text) {
        const textarea = document.createElement('textarea');
        textarea.value = text;
        textarea.setAttribute('readonly', '');
        textarea.style.position = 'absolute';
        textarea.style.left = '-9999px';
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand('copy');
        document.body.removeChild(textarea);
      }

      document.querySelectorAll('.copy-btn').forEach(function (button) {
        button.addEventListener('click', function () {
          writeClipboard(button.getAttribute('data-copy'), button);
        });
      });

      function selectedAsset() {
        const select = document.getElementById('assetSelect');
        const option = select.options[select.selectedIndex];
        return { id: option.value, vs: option.getAttribute('data-vs') || 'usd' };
      }

      function liveUrl(kind) {
        const asset = selectedAsset();
        if (kind === 'asset') {
          return '/api/v1/assets/' + encodeURIComponent(asset.id);
        }
        if (kind === 'history') {
          const interval = document.getElementById('intervalSelect').value;
          const limit = document.getElementById('limitInput').value || '5';
          return '/api/v1/history/' + encodeURIComponent(asset.id) + '?interval=' + encodeURIComponent(interval) + '&vs=' + encodeURIComponent(asset.vs) + '&limit=' + encodeURIComponent(limit);
        }
        return '/api/v1/assets';
      }

      document.querySelectorAll('.live-btn').forEach(function (button) {
        button.addEventListener('click', async function () {
          const url = liveUrl(button.getAttribute('data-kind'));
          const link = document.getElementById('liveUrl');
          const output = document.getElementById('liveOutput');
          link.href = url;
          link.textContent = url;
          output.textContent = 'Loading ' + url + ' ...';

          try {
            const response = await fetch(url, { headers: { Accept: 'application/json' } });
            const text = await response.text();
            try {
              output.textContent = JSON.stringify(JSON.parse(text), null, 2);
            } catch (parseError) {
              output.textContent = text;
            }
          } catch (error) {
            output.textContent = 'Request failed: ' + error.message;
          }
        });
      });
    </script>
  </body>
</html>
