<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/public/css/app.css" rel="stylesheet">
    <script src="/public/js/admin-nav.js" defer></script>
  </head>
  <body>
    <%- include('admin-nav') %>

    <%- include('admin-maintenance-banner') %>

    <main class="container py-5">
      <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
        <div>
          <h1 class="display-6 fw-bold mb-1">Solo-maintainer runbook</h1>
          <p class="lead text-body-secondary mb-0">Operational checklist and recovery commands from <code>docs/RUNBOOK.md</code>.</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
          <a class="btn btn-outline-primary" href="/admin">Dashboard</a>
          <a class="btn btn-outline-secondary" href="/admin/doctor">Admin Doctor</a>
        </div>
      </div>

      <article class="card shadow-sm runbook-card">
        <div class="card-body">
          <%- runbookHtml %>
        </div>
      </article>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
