<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/public/css/app.css" rel="stylesheet">
  </head>
  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container-fluid">
        <a class="navbar-brand" href="/admin"><%= appName %></a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNavbar" aria-controls="adminNavbar" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="adminNavbar">
          <ul class="navbar-nav me-auto mb-2 mb-lg-0">
            <li class="nav-item"><a class="nav-link" href="/admin">Dashboard</a></li>
            <li class="nav-item"><a class="nav-link" href="/admin/assets">Assets</a></li>
            <li class="nav-item"><a class="nav-link active" aria-current="page" href="/admin/imports">Imports</a></li>
            <li class="nav-item"><a class="nav-link" href="/admin/api-test">API test</a></li>
            <li class="nav-item"><a class="nav-link" href="/admin/reload-status">Reload status</a></li>
            <li class="nav-item"><a class="nav-link" href="/admin/system-health">System health</a></li>
            <li class="nav-item"><a class="nav-link" href="/admin/logs">Logs</a></li>
            <li class="nav-item"><a class="nav-link" href="/admin/runbook">Runbook</a></li>
            <li class="nav-item"><a class="nav-link" href="/admin/logout">Logout</a></li>
          </ul>
        </div>
      </div>
    </nav>

    <%- include('admin-maintenance-banner') %>

    <main class="container py-4">
      <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
        <div>
          <h1 class="mb-1">Import inbox</h1>
          <p class="text-secondary mb-0">Drop raw CSV or JSON files into <code>data/imports</code>. Files are hashed, registered once, and never deleted automatically.</p>
        </div>
        <a href="/admin" class="btn btn-outline-secondary">Back to dashboard</a>
      </div>

      <% if (error) { %>
        <div class="alert alert-danger" role="alert"><%= error %></div>
      <% } %>
      <% if (previewError) { %>
        <div class="alert alert-warning" role="alert">Preview failed: <%= previewError %></div>
      <% } %>
      <% if (maintenanceMode) { %>
        <div class="alert alert-warning" role="alert">Imports are paused while maintenance mode is active.</div>
      <% } %>

      <% if (result) { %>
        <div class="alert alert-success" role="alert">
          <div class="fw-semibold">Import workflow #<%= result.runId %> completed.</div>
          <div><%= result.rowsImported %> row change(s) from <%= result.rowsSeen %> row(s) seen using <code><%= result.policy %></code>.</div>
          <div>Workflow file: <code><%= result.normalizedFile %></code></div>
          <% if (result.rawFile) { %><div>Raw file kept at: <code><%= result.rawFile %></code></div><% } %>
          <% if (result.conversionReport) { %>
            <div>Converted <%= result.conversionReport.rowsConverted %> row(s); skipped <%= result.conversionReport.rowsSkipped %>; detected <code><%= result.conversionReport.detectedFormat %></code>.</div>
          <% } %>
        </div>
      <% } %>

      <div class="card shadow-sm mb-4">
        <div class="card-header bg-white">
          <h2 class="h5 mb-0">Solo-developer import workflow</h2>
        </div>
        <div class="card-body">
          <ol class="row row-cols-1 row-cols-md-3 g-3 list-unstyled mb-0">
            <% ['Preview', 'Map columns', 'Convert', 'Validate', 'Import', 'Archive'].forEach((step, index) => { %>
              <li class="col">
                <div class="border rounded p-3 h-100">
                  <span class="badge text-bg-primary me-2"><%= index + 1 %></span><span class="fw-semibold"><%= step %></span>
                </div>
              </li>
            <% }) %>
          </ol>
        </div>
      </div>

      <div class="row g-4">
        <section class="col-lg-4">
          <div class="card shadow-sm mb-4">
            <div class="card-header bg-white">
              <h2 class="h5 mb-0">Inbox files</h2>
            </div>
            <div class="list-group list-group-flush">
              <% if (files.length === 0) { %>
                <div class="list-group-item text-secondary">No files found in <code>data/imports</code>.</div>
              <% } %>
              <% files.forEach((file) => { %>
                <a class="list-group-item list-group-item-action <%= selectedImportFile && file.id === selectedImportFile.id ? 'active' : '' %>" href="/admin/imports?importFileId=<%= file.id %>&asset=<%= encodeURIComponent(selectedAssetId) %>&interval=<%= encodeURIComponent(selectedInterval) %>&policy=<%= encodeURIComponent(selectedPolicy) %>">
                  <div class="d-flex w-100 justify-content-between gap-2">
                    <span class="text-break"><%= file.filename %></span>
                    <span class="badge text-bg-<%= file.status === 'failed' ? 'danger' : (file.status === 'imported' ? 'success' : 'secondary') %>"><%= file.status %></span>
                  </div>
                  <small class="<%= selectedImportFile && file.id === selectedImportFile.id ? 'text-white-50' : 'text-secondary' %>"><%= file.size %> B · sha256:<%= file.shortHash %><br><%= file.updatedAtIso %></small>
                  <% if (file.lastError) { %><div><small class="text-danger"><%= file.lastError %></small></div><% } %>
                </a>
              <% }) %>
            </div>
          </div>
        </section>

        <section class="col-lg-8">
          <div class="card shadow-sm mb-4">
            <div class="card-header bg-white">
              <h2 class="h5 mb-0">Map, convert, validate, import</h2>
            </div>
            <div class="card-body">
              <form method="post" action="/admin/imports/run" class="row g-3">
                <input type="hidden" name="importFileId" value="<%= selectedImportFile ? selectedImportFile.id : '' %>">
                <div class="col-12">
                  <label class="form-label" for="file">Import file</label>
                  <select class="form-select" id="file" name="file" required>
                    <% files.forEach((file) => { %>
                      <option value="<%= file.filename %>" <%= selectedImportFile && file.id === selectedImportFile.id ? 'selected' : '' %>><%= file.filename %> (<%= file.status %>)</option>
                    <% }) %>
                  </select>
                </div>
                <div class="col-md-4">
                  <label class="form-label" for="assetId">Asset</label>
                  <select class="form-select" id="assetId" name="assetId" required>
                    <% assets.forEach((asset) => { %>
                      <option value="<%= asset.id %>" <%= asset.id === selectedAssetId ? 'selected' : '' %>><%= asset.symbol %> — <%= asset.id %></option>
                    <% }) %>
                  </select>
                </div>
                <div class="col-md-4">
                  <label class="form-label" for="interval">Interval</label>
                  <select class="form-select" id="interval" name="interval" required>
                    <% intervals.forEach((interval) => { %>
                      <option value="<%= interval %>" <%= interval === selectedInterval ? 'selected' : '' %>><%= interval %></option>
                    <% }) %>
                  </select>
                </div>
                <div class="col-md-4">
                  <label class="form-label" for="policy">Conflict policy</label>
                  <select class="form-select" id="policy" name="policy" required>
                    <% policies.forEach((policy) => { %>
                      <option value="<%= policy %>" <%= policy === selectedPolicy ? 'selected' : '' %>><%= policy %></option>
                    <% }) %>
                  </select>
                </div>
                <div class="col-12">
                  <div class="form-text">Column mapping is auto-detected from common timestamp, OHLC, volume, and market-cap headers. Validate the preview before importing.</div>
                </div>
                <div class="col-12 d-flex flex-wrap gap-2">
                  <button type="submit" class="btn btn-primary" <%= (files.length === 0 || maintenanceMode || (selectedImportFile && selectedImportFile.status === 'imported')) ? 'disabled' : '' %>>Convert, validate, and import</button>
                  <% if (selectedImportFile) { %>
                    <a class="btn btn-outline-secondary" href="/admin/imports?importFileId=<%= selectedImportFile.id %>&asset=<%= encodeURIComponent(selectedAssetId) %>&interval=<%= encodeURIComponent(selectedInterval) %>&policy=<%= encodeURIComponent(selectedPolicy) %>">Preview / refresh</a>
                  <% } %>
                </div>
              </form>
              <% if (selectedImportFile) { %>
                <form method="post" action="/admin/imports/archive" class="mt-3">
                  <input type="hidden" name="importFileId" value="<%= selectedImportFile.id %>">
                  <button type="submit" class="btn btn-outline-dark">Archive raw file</button>
                  <span class="form-text ms-2">Manual action; raw files are not archived or deleted automatically.</span>
                </form>
              <% } %>
            </div>
          </div>

          <div class="card shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center flex-wrap gap-2">
              <h2 class="h5 mb-0">Preview and validation</h2>
              <% if (preview) { %>
                <span class="badge text-bg-secondary"><%= preview.rowsSeen %> row(s), <%= preview.detectedFormat %></span>
              <% } %>
            </div>
            <div class="card-body">
              <% if (!preview) { %>
                <p class="text-secondary mb-0">Choose an inbox file to preview import rows.</p>
              <% } else { %>
                <dl class="row small mb-3">
                  <dt class="col-sm-3">State</dt><dd class="col-sm-9"><span class="badge text-bg-secondary"><%= selectedImportFile ? selectedImportFile.status : 'previewed' %></span></dd>
                  <dt class="col-sm-3">Asset</dt><dd class="col-sm-9"><code><%= preview.assetId || selectedAssetId %></code></dd>
                  <dt class="col-sm-3">Currency</dt><dd class="col-sm-9"><code><%= preview.vsCurrency || 'usd' %></code></dd>
                  <dt class="col-sm-3">Interval</dt><dd class="col-sm-9"><code><%= preview.interval || selectedInterval %></code></dd>
                </dl>
                <div class="table-responsive">
                  <table class="table table-sm table-striped align-middle mb-0">
                    <thead>
                      <tr>
                        <th>Timestamp</th>
                        <th>Open</th>
                        <th>High</th>
                        <th>Low</th>
                        <th>Close</th>
                        <th>Volume</th>
                        <th>Market cap</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% preview.candles.forEach((candle) => { %>
                        <tr>
                          <td><code><%= candle.ts %></code><br><small class="text-secondary"><%= new Date(candle.ts).toISOString() %></small></td>
                          <td><%= candle.open === null || candle.open === undefined ? '—' : candle.open %></td>
                          <td><%= candle.high === null || candle.high === undefined ? '—' : candle.high %></td>
                          <td><%= candle.low === null || candle.low === undefined ? '—' : candle.low %></td>
                          <td><%= candle.close %></td>
                          <td><%= candle.volume === null || candle.volume === undefined ? '—' : candle.volume %></td>
                          <td><%= candle.marketCap === null || candle.marketCap === undefined ? '—' : candle.marketCap %></td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              <% } %>
            </div>
          </div>
        </section>
      </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
