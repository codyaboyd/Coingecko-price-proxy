<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/public/css/app.css" rel="stylesheet">
  </head>
  <body>
    <nav class="navbar navbar-expand-lg bg-dark navbar-dark">
      <div class="container">
        <a class="navbar-brand" href="/admin"><%= appName %></a>
        <div class="navbar-nav ms-auto">
          <a class="nav-link" href="/admin/settings">Settings</a>
          <a class="nav-link" href="/admin/assets">Assets</a>
          <a class="nav-link" href="/admin/imports">Imports</a>
          <a class="nav-link" href="/admin/backups">Backups</a>
          <a class="nav-link active" aria-current="page" href="/admin/cleanup">Cleanup</a>
          <a class="nav-link" href="/admin/activity">Activity</a>
          <a class="nav-link" href="/admin/doctor">Doctor</a>
          <a class="nav-link" href="/admin/system-health">System Health</a>
          <a class="nav-link" href="/admin/logs">Logs</a>
          <%- include('admin-alert-bell') %>
          <a class="nav-link" href="/admin/logout">Logout</a>
        </div>
      </div>
    </nav>

    <%- include('admin-maintenance-banner') %>

    <main class="container py-5">
      <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
        <div>
          <h1 class="display-6 fw-bold mb-2">Automatic cleanup</h1>
          <p class="lead mb-0">Daily maintenance tasks prune only operational data. Raw historical candle rows are never deleted by cleanup.</p>
        </div>
        <form method="post" action="/admin/cleanup/run">
          <button type="submit" class="btn btn-primary" <%= cleanup.running ? 'disabled' : '' %>>Run cleanup now</button>
        </form>
      </div>

      <% if (cleanupAction) { %>
        <div class="alert alert-info alert-dismissible fade show" role="alert">
          Cleanup action: <strong><%= cleanupAction %></strong><% if (cleanupDetails) { %> — <%= cleanupDetails %><% } %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% } %>

      <div class="row g-3 mb-4">
        <div class="col-md-4">
          <div class="card shadow-sm h-100">
            <div class="card-body">
              <p class="text-uppercase text-secondary small fw-semibold mb-1">Last cleanup time</p>
              <p class="h5 mb-0"><%= cleanup.lastRun && cleanup.lastRun.finishedAtIso ? cleanup.lastRun.finishedAtIso : 'Never' %></p>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card shadow-sm h-100">
            <div class="card-body">
              <p class="text-uppercase text-secondary small fw-semibold mb-1">Next cleanup time</p>
              <p class="h5 mb-0"><%= cleanup.nextRunAtIso || 'Not scheduled' %></p>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card shadow-sm h-100">
            <div class="card-body">
              <p class="text-uppercase text-secondary small fw-semibold mb-1">Scheduler status</p>
              <% if (cleanup.running) { %>
                <span class="badge text-bg-warning">Running</span>
              <% } else { %>
                <span class="badge text-bg-success">Idle</span>
              <% } %>
            </div>
          </div>
        </div>
      </div>

      <div class="card shadow-sm mb-4 border-success">
        <div class="card-header bg-success-subtle">
          <h2 class="h5 mb-1">Historical data safety</h2>
          <p class="small text-secondary mb-0">Cleanup tasks do not delete from the <code>candles</code> table.</p>
        </div>
        <div class="card-body">
          <p class="mb-0">Last run reported <strong><%= cleanup.lastRun && cleanup.lastRun.summary ? cleanup.lastRun.summary.historicalCandlesDeleted : 0 %></strong> raw historical candle rows deleted.</p>
        </div>
      </div>

      <div class="card shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center flex-wrap gap-2">
          <div>
            <h2 class="h5 mb-1">What was cleaned</h2>
            <p class="small text-secondary mb-0">Most recent cleanup run summary.</p>
          </div>
          <% if (cleanup.lastRun) { %>
            <span class="badge <%= cleanup.lastRun.status === 'completed' ? 'text-bg-success' : 'text-bg-danger' %>"><%= cleanup.lastRun.status %></span>
          <% } %>
        </div>
        <div class="table-responsive">
          <table class="table table-striped align-middle mb-0">
            <thead>
              <tr>
                <th scope="col">Task</th>
                <th scope="col" class="text-end">Result</th>
              </tr>
            </thead>
            <tbody>
              <% if (!cleanup.lastRun) { %>
                <tr>
                  <td colspan="2" class="text-center text-secondary py-5">Cleanup has not run yet.</td>
                </tr>
              <% } %>
              <% cleanup.summaryItems.forEach((item) => { %>
                <tr>
                  <td><%= item.label %></td>
                  <td class="text-end"><%= item.value %></td>
                </tr>
              <% }) %>
              <% if (cleanup.lastRun && cleanup.lastRun.error) { %>
                <tr>
                  <td>Error</td>
                  <td class="text-end text-danger"><%= cleanup.lastRun.error %></td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
