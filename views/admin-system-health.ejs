<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/public/css/app.css" rel="stylesheet">
  </head>
  <body>
    <nav class="navbar navbar-expand-lg bg-dark navbar-dark">
      <div class="container">
        <a class="navbar-brand" href="/admin"><%= appName %></a>
        <div class="navbar-nav ms-auto">
          <a class="nav-link" href="/admin/assets">Assets</a>
          <a class="nav-link" href="/admin/imports">Imports</a>
          <a class="nav-link" href="/admin/backups">Backups</a>
          <a class="nav-link" href="/admin/doctor">Doctor</a>
          <a class="nav-link" href="/admin/reload-status">Reload Status</a>
          <a class="nav-link active" href="/admin/system-health">System Health</a>
          <a class="nav-link" href="/admin/logs">Logs</a>
          <a class="nav-link" href="/admin/api-test">API Test</a>
          <a class="nav-link" href="/admin/runbook">Runbook</a>
          <%- include('admin-alert-bell') %>
          <a class="nav-link" href="/admin/logout">Logout</a>
        </div>
      </div>
    </nav>

    <%- include('admin-maintenance-banner') %>

    <% const badgeClass = (status) => status === 'ok' ? 'text-bg-success' : (status === 'warning' || status === 'degraded' ? 'text-bg-warning' : 'text-bg-danger'); %>
    <% const textClass = (status) => status === 'ok' ? 'text-success' : (status === 'warning' || status === 'degraded' ? 'text-warning' : 'text-danger'); %>

    <main class="container py-4 py-md-5">
      <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
        <div>
          <h1 class="display-6 fw-bold mb-1">System Health</h1>
          <p class="lead text-body-secondary mb-0">Solo-maintainer dashboard for runtime, storage, scheduler, queue, CoinGecko, data, import, and backup health.</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
          <a class="btn btn-outline-primary" href="/api/v1/admin/system-health">JSON endpoint</a>
          <a class="btn btn-outline-secondary" href="/admin">Back to dashboard</a>
        </div>
      </div>

      <div class="card shadow-sm mb-4 border-0">
        <div class="card-body">
          <div class="row g-3 align-items-center">
            <div class="col-md-4">
              <p class="text-uppercase text-secondary small fw-semibold mb-1">Overall status</p>
              <span class="badge fs-6 <%= badgeClass(health.status) %>"><%= health.status %></span>
            </div>
            <div class="col-md-4">
              <p class="text-uppercase text-secondary small fw-semibold mb-1">Generated</p>
              <p class="mb-0"><%= health.generatedAtIso %></p>
            </div>
            <div class="col-md-4">
              <p class="text-uppercase text-secondary small fw-semibold mb-1">Runtime</p>
              <p class="mb-0"><code><%= health.app.runtime.name %> <%= health.app.runtime.version %></code></p>
            </div>
          </div>
          <div class="row g-3 mt-1">
            <div class="col-4">
              <div class="p-3 rounded bg-success-subtle text-center">
                <div class="h3 mb-0"><%= health.summary.ok %></div>
                <div class="small text-uppercase fw-semibold">OK</div>
              </div>
            </div>
            <div class="col-4">
              <div class="p-3 rounded bg-warning-subtle text-center">
                <div class="h3 mb-0"><%= health.summary.warning %></div>
                <div class="small text-uppercase fw-semibold">Warning</div>
              </div>
            </div>
            <div class="col-4">
              <div class="p-3 rounded bg-danger-subtle text-center">
                <div class="h3 mb-0"><%= health.summary.critical %></div>
                <div class="small text-uppercase fw-semibold">Critical</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <% const runtimeCompatibilityCheck = health.checks.find((item) => item.id === 'runtime_compatibility'); %>
      <% if (runtimeCompatibilityCheck && runtimeCompatibilityCheck.details && Array.isArray(runtimeCompatibilityCheck.details.checks)) { %>
        <section class="card shadow-sm mb-4">
          <div class="card-header bg-white d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
              <h2 class="h5 mb-1">Runtime Compatibility</h2>
              <p class="small text-secondary mb-0">Maintenance checks for Node.js, optional Bun, npm, screen, SQLite loading, package scripts, lockfile, node_modules, and required directories.</p>
            </div>
            <span class="badge <%= badgeClass(runtimeCompatibilityCheck.status) %>"><%= runtimeCompatibilityCheck.status %></span>
          </div>
          <div class="table-responsive">
            <table class="table table-sm table-striped align-middle mb-0">
              <thead>
                <tr>
                  <th scope="col">Check</th>
                  <th scope="col">Status</th>
                  <th scope="col">Summary</th>
                </tr>
              </thead>
              <tbody>
                <% runtimeCompatibilityCheck.details.checks.forEach((item) => { %>
                  <tr>
                    <td><%= item.label %></td>
                    <td><span class="badge <%= badgeClass(item.status) %>"><%= item.status %></span></td>
                    <td><%= item.summary %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </section>
      <% } %>

      <div class="row g-3 mb-4">
        <% health.checks.forEach((item) => { %>
          <div class="col-md-6 col-xl-4">
            <div class="card shadow-sm h-100 health-card health-card-<%= item.status %>">
              <div class="card-body">
                <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                  <h2 class="h6 mb-0"><%= item.label %></h2>
                  <span class="badge <%= badgeClass(item.status) %>"><%= item.status %></span>
                </div>
                <p class="fs-5 mb-0 <%= textClass(item.status) %>"><%= item.summary %></p>
              </div>
            </div>
          </div>
        <% }) %>
      </div>

      <% const latestFetchCheck = health.checks.find((item) => item.id === 'latest_successful_fetch_per_asset'); %>
      <% if (latestFetchCheck && Array.isArray(latestFetchCheck.details)) { %>
        <div class="card shadow-sm mb-4">
          <div class="card-header bg-white d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
              <h2 class="h5 mb-1">Latest successful fetch per asset</h2>
              <p class="small text-secondary mb-0">Enabled assets only. Stale means the latest stored fetch is older than twice the asset refresh interval.</p>
            </div>
            <span class="badge <%= badgeClass(latestFetchCheck.status) %>"><%= latestFetchCheck.status %></span>
          </div>
          <div class="table-responsive">
            <table class="table table-sm table-striped align-middle mb-0">
              <thead>
                <tr>
                  <th scope="col">Asset</th>
                  <th scope="col">Latest success</th>
                  <th scope="col">Latest candle</th>
                  <th scope="col">Latest stored fetch</th>
                  <th scope="col">Candles</th>
                  <th scope="col">Data status</th>
                </tr>
              </thead>
              <tbody>
                <% latestFetchCheck.details.forEach((asset) => { %>
                  <tr>
                    <td><span class="fw-semibold"><%= asset.symbol %></span> <code><%= asset.assetId %></code></td>
                    <td><%= asset.latestSuccessfulFetchIso || 'Never' %></td>
                    <td><%= asset.latestCandleIso || '—' %></td>
                    <td><%= asset.latestFetchedAtIso || '—' %></td>
                    <td><%= asset.candleCount %></td>
                    <td>
                      <% if (asset.noCandles) { %>
                        <span class="badge text-bg-danger">no candles</span>
                      <% } else if (asset.stale) { %>
                        <span class="badge text-bg-warning">stale</span>
                      <% } else { %>
                        <span class="badge text-bg-success">fresh</span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      <% } %>

      <div class="row g-4">
        <% const activeJobCheck = health.checks.find((item) => item.id === 'active_job'); %>
        <% const failedJobsCheck = health.checks.find((item) => item.id === 'failed_jobs_last_24h'); %>
        <% const pendingImportsCheck = health.checks.find((item) => item.id === 'pending_import_files'); %>
        <% const latestBackupCheck = health.checks.find((item) => item.id === 'latest_backup_time'); %>

        <section class="col-lg-6">
          <div class="card shadow-sm h-100">
            <div class="card-header bg-white">
              <h2 class="h5 mb-0">Queue detail</h2>
            </div>
            <div class="card-body">
              <% if (activeJobCheck && activeJobCheck.details) { %>
                <dl class="mb-3">
                  <dt>Active job</dt>
                  <dd><code>#<%= activeJobCheck.details.id %></code> <%= activeJobCheck.details.type %> for <%= activeJobCheck.details.payload.assetId || 'n/a' %></dd>
                  <dt>Started</dt>
                  <dd><%= activeJobCheck.details.startedAt ? new Date(activeJobCheck.details.startedAt).toISOString() : '—' %></dd>
                </dl>
              <% } else { %>
                <p class="text-secondary">No active job is running.</p>
              <% } %>

              <% if (failedJobsCheck && Array.isArray(failedJobsCheck.details) && failedJobsCheck.details.length > 0) { %>
                <div class="fw-semibold mb-2">Failures in the last 24 hours</div>
                <ul class="mb-0">
                  <% failedJobsCheck.details.forEach((job) => { %>
                    <li><code>#<%= job.id %></code> <%= job.type %>: <%= job.error %></li>
                  <% }) %>
                </ul>
              <% } else { %>
                <p class="mb-0 text-success">No failed jobs in the last 24 hours.</p>
              <% } %>
            </div>
          </div>
        </section>

        <section class="col-lg-6">
          <div class="card shadow-sm h-100">
            <div class="card-header bg-white">
              <h2 class="h5 mb-0">Imports and backups</h2>
            </div>
            <div class="card-body">
              <dl>
                <dt>Pending import files</dt>
                <dd><%= pendingImportsCheck ? pendingImportsCheck.summary : 'Unavailable' %></dd>
                <dt>Latest backup</dt>
                <dd>
                  <% if (latestBackupCheck && latestBackupCheck.details) { %>
                    <div><%= latestBackupCheck.details.updatedAtIso %></div>
                    <code><%= latestBackupCheck.details.path %></code>
                    <div class="small text-secondary"><%= bytesToSummary(latestBackupCheck.details.sizeBytes) %></div>
                  <% } else { %>
                    No backups found.
                  <% } %>
                </dd>
              </dl>
              <% if (pendingImportsCheck && Array.isArray(pendingImportsCheck.details) && pendingImportsCheck.details.length > 0) { %>
                <div class="table-responsive">
                  <table class="table table-sm mb-0">
                    <thead><tr><th>File</th><th>Updated</th><th>Size</th></tr></thead>
                    <tbody>
                      <% pendingImportsCheck.details.slice(0, 10).forEach((file) => { %>
                        <tr>
                          <td><code><%= file.name %></code></td>
                          <td><%= file.updatedAtIso %></td>
                          <td><%= bytesToSummary(file.sizeBytes) %></td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              <% } %>
            </div>
          </div>
        </section>
      </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
