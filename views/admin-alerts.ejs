<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/public/css/app.css" rel="stylesheet">
  </head>
  <body>
    <nav class="navbar navbar-expand-lg bg-dark navbar-dark">
      <div class="container">
        <a class="navbar-brand" href="/admin"><%= appName %></a>
        <div class="navbar-nav ms-auto">
          <a class="nav-link" href="/admin/assets">Assets</a>
          <a class="nav-link" href="/admin/imports">Imports</a>
          <a class="nav-link" href="/admin/backups">Backups</a>
          <a class="nav-link" href="/admin/system-health">System Health</a>
          <a class="nav-link" href="/admin/db-integrity">DB Integrity</a>
          <%- include('admin-alert-bell') %>
          <a class="nav-link" href="/admin/logout">Logout</a>
        </div>
      </div>
    </nav>

    <%- include('admin-maintenance-banner') %>

    <main class="container py-5">
      <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-4">
        <div>
          <h1 class="display-6 fw-bold mb-1">Alerts</h1>
          <p class="text-secondary mb-0">Local alerts for important failures. Webhooks are optional via <code>ALERT_WEBHOOK_URL</code>.</p>
        </div>
        <div class="btn-group" role="group" aria-label="Alert filters">
          <% ['all', 'open', 'acknowledged', 'resolved'].forEach((status) => { %>
            <a class="btn btn-sm <%= selectedStatus === status ? 'btn-primary' : 'btn-outline-primary' %>" href="/admin/alerts<%= status === 'all' ? '' : `?status=${status}` %>"><%= status %></a>
          <% }) %>
        </div>
      </div>

      <% if (alertAction) { %>
        <div class="alert alert-info alert-dismissible fade show" role="alert">
          Alert <strong><%= alertAction %></strong><% if (alertDetails) { %> — <%= alertDetails %><% } %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% } %>

      <div class="card shadow-sm">
        <div class="card-header bg-white d-flex align-items-center justify-content-between">
          <h2 class="h5 mb-0">Alert history</h2>
          <span class="badge text-bg-secondary"><%= alerts.length %> shown</span>
        </div>
        <div class="card-body">
          <% if (alerts.length === 0) { %>
            <p class="text-secondary mb-0">No alerts match this filter.</p>
          <% } else { %>
            <div class="table-responsive">
              <table class="table align-middle">
                <thead>
                  <tr>
                    <th>ID</th>
                    <th>Severity</th>
                    <th>Status</th>
                    <th>Type</th>
                    <th>Title</th>
                    <th>Entity</th>
                    <th>Created</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% alerts.forEach((alert) => { %>
                    <tr>
                      <td><code>#<%= alert.id %></code></td>
                      <td><span class="badge <%= alert.severity === 'critical' ? 'text-bg-danger' : (alert.severity === 'warning' ? 'text-bg-warning' : 'text-bg-info') %>"><%= alert.severity %></span></td>
                      <td><span class="badge <%= alert.status === 'open' ? 'text-bg-danger' : (alert.status === 'acknowledged' ? 'text-bg-warning' : 'text-bg-success') %>"><%= alert.status %></span></td>
                      <td><code><%= alert.type %></code></td>
                      <td>
                        <strong><%= alert.title %></strong>
                        <div class="small text-secondary"><%= alert.message %></div>
                      </td>
                      <td><%= alert.entityType || '—' %><% if (alert.entityId) { %>: <code><%= alert.entityId %></code><% } %></td>
                      <td><%= alert.createdAtIso %></td>
                      <td>
                        <div class="d-flex gap-2">
                          <% if (alert.status === 'open') { %>
                            <form method="post" action="/admin/alerts/<%= alert.id %>/acknowledge" class="m-0">
                              <button type="submit" class="btn btn-outline-warning btn-sm">Acknowledge</button>
                            </form>
                          <% } %>
                          <% if (alert.status !== 'resolved') { %>
                            <form method="post" action="/admin/alerts/<%= alert.id %>/resolve" class="m-0">
                              <button type="submit" class="btn btn-outline-success btn-sm">Resolve</button>
                            </form>
                          <% } %>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </div>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
