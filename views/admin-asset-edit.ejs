<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/public/css/app.css" rel="stylesheet">
  </head>
  <body>
    <nav class="navbar navbar-expand-lg bg-dark navbar-dark">
      <div class="container">
        <a class="navbar-brand" href="/admin"><%= appName %></a>
        <div class="navbar-nav ms-auto">
          <a class="nav-link" href="/admin/assets">Assets</a>
          <a class="nav-link" href="/admin/imports">Imports</a>
          <a class="nav-link" href="/admin/backups">Backups</a>
          <a class="nav-link" href="/admin/system-health">System Health</a>
          <a class="nav-link" href="/admin/db-integrity">DB Integrity</a>
          <a class="nav-link" href="/admin/rate-budget">Rate Budget</a>
          <a class="nav-link" href="/admin/logs">Logs</a>
          <a class="nav-link" href="/admin/api-test">API Test</a>
          <%- include('admin-alert-bell') %>
          <a class="nav-link" href="/admin/logout">Logout</a>
        </div>
      </div>
    </nav>

    <%- include('admin-maintenance-banner') %>

    <main class="container py-5">
      <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
        <div>
          <h1 class="display-6 fw-bold mb-1">Edit <%= asset.symbol %></h1>
          <p class="lead text-body-secondary mb-0">Safely update the configured asset entry in <code>config/assets.json</code>.</p>
        </div>
        <div class="d-flex gap-2">
          <a class="btn btn-outline-secondary" href="/admin/assets">Back to assets</a>
          <a class="btn btn-outline-primary" href="/admin/assets/<%= encodeURIComponent(asset.id) %>">Manage asset</a>
        </div>
      </div>

      <% if (alert && message) { %>
        <div class="alert alert-<%= alert %> alert-dismissible fade show" role="alert">
          <%= message %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% } %>

      <div id="actionAlert" class="alert d-none" role="alert"></div>

      <div class="row g-4">
        <section class="col-lg-7">
          <div class="card shadow-sm">
            <div class="card-header bg-white">
              <h2 class="h5 mb-0">Editable fields</h2>
            </div>
            <div class="card-body">
              <form method="post" action="/admin/assets/<%= encodeURIComponent(asset.id) %>/edit" class="vstack gap-3">
                <div>
                  <label class="form-label" for="assetId">Asset ID</label>
                  <input id="assetId" class="form-control" value="<%= asset.id %>" disabled>
                  <div class="form-text">The asset ID is not editable from this page.</div>
                </div>

                <div class="row g-3">
                  <div class="col-md-6">
                    <label class="form-label" for="name">Name</label>
                    <input id="name" name="name" class="form-control" value="<%= asset.name %>" required>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label" for="symbol">Symbol</label>
                    <input id="symbol" name="symbol" class="form-control" value="<%= asset.symbol %>" required>
                  </div>
                </div>

                <div class="row g-3">
                  <div class="col-md-6">
                    <label class="form-label" for="coingeckoId">CoinGecko ID</label>
                    <input id="coingeckoId" name="coingeckoId" class="form-control" value="<%= asset.coingeckoId %>" required>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label" for="vsCurrency">Currency</label>
                    <input id="vsCurrency" name="vsCurrency" class="form-control" value="<%= asset.vsCurrency %>" required>
                  </div>
                </div>

                <div class="row g-3 align-items-end">
                  <div class="col-md-4">
                    <label class="form-label" for="priority">Priority</label>
                    <input id="priority" name="priority" type="number" min="0" step="1" class="form-control" value="<%= asset.priority %>" required>
                  </div>
                  <div class="col-md-4">
                    <div class="form-check form-switch">
                      <input id="enabled" name="enabled" class="form-check-input" type="checkbox" <%= asset.enabled ? 'checked' : '' %>>
                      <label class="form-check-label" for="enabled">Enabled</label>
                    </div>
                  </div>
                </div>

                <hr>

                <h3 class="h6">Fetch policy</h3>
                <div class="row g-3">
                  <div class="col-md-4">
                    <label class="form-label" for="recentEveryMinutes">Recent every minutes</label>
                    <input id="recentEveryMinutes" name="recentEveryMinutes" type="number" min="1" step="1" class="form-control" value="<%= (asset.fetchPolicy && asset.fetchPolicy.recentEveryMinutes) || 60 %>" required>
                  </div>
                  <div class="col-md-4">
                    <label class="form-label" for="maxBackfillDaysPerRun">Max backfill days/run</label>
                    <input id="maxBackfillDaysPerRun" name="maxBackfillDaysPerRun" type="number" min="1" step="1" class="form-control" value="<%= (asset.fetchPolicy && asset.fetchPolicy.maxBackfillDaysPerRun) || 10 %>" required>
                  </div>
                  <div class="col-md-4 d-flex align-items-end">
                    <div class="form-check form-switch">
                      <input id="dailyBackfill" name="dailyBackfill" class="form-check-input" type="checkbox" <%= asset.fetchPolicy && asset.fetchPolicy.dailyBackfill ? 'checked' : '' %>>
                      <label class="form-check-label" for="dailyBackfill">Daily backfill</label>
                    </div>
                  </div>
                </div>

                <div class="alert alert-info mb-0">
                  Saving writes pretty JSON, creates a timestamped backup beside <code>config/assets.json</code>, and refreshes runtime asset state without allowing arbitrary file edits.
                </div>

                <div class="d-flex gap-2 flex-wrap">
                  <button type="submit" class="btn btn-primary">Save asset config</button>
                  <a class="btn btn-outline-secondary" href="/admin/assets">Cancel</a>
                </div>
              </form>
            </div>
          </div>
        </section>

        <aside class="col-lg-5">
          <div class="card shadow-sm mb-4">
            <div class="card-header bg-white">
              <h2 class="h5 mb-0">Test buttons</h2>
            </div>
            <div class="card-body">
              <div class="row g-3 mb-3">
                <div class="col-sm-6">
                  <label class="form-label" for="testFrom">From</label>
                  <input id="testFrom" type="datetime-local" class="form-control">
                </div>
                <div class="col-sm-6">
                  <label class="form-label" for="testTo">To</label>
                  <input id="testTo" type="datetime-local" class="form-control">
                </div>
                <div class="col-sm-6">
                  <label class="form-label" for="testInterval">Interval</label>
                  <select id="testInterval" class="form-select">
                    <% intervals.forEach((interval) => { %>
                      <option value="<%= interval %>" <%= interval === range.interval ? 'selected' : '' %>><%= interval %></option>
                    <% }) %>
                  </select>
                </div>
                <div class="col-sm-6">
                  <label class="form-label" for="testVsCurrency">Currency</label>
                  <input id="testVsCurrency" class="form-control" value="<%= range.vsCurrency %>">
                </div>
              </div>

              <div class="d-grid gap-2">
                <button type="button" class="btn btn-outline-primary" data-action="coingecko">Test CoinGecko</button>
                <button type="button" class="btn btn-outline-secondary" data-action="local-history">Test local history</button>
                <button type="button" class="btn btn-outline-primary" data-action="gap-report">Run gap report</button>
                <button type="button" class="btn btn-primary" data-action="fetch-recent">Fetch recent</button>
              </div>
            </div>
          </div>

          <div class="card shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
              <h2 class="h5 mb-0">Test response</h2>
              <span id="testStatus" class="badge text-bg-secondary">Not run</span>
            </div>
            <div class="card-body">
              <pre id="testResponse" class="bg-body-tertiary border rounded p-3 mb-0 small" style="min-height: 20rem; white-space: pre-wrap;">Choose a test action.</pre>
            </div>
          </div>
        </aside>
      </div>
    </main>

    <script>
      const actionAlert = document.getElementById('actionAlert');
      const testStatus = document.getElementById('testStatus');
      const testResponse = document.getElementById('testResponse');
      const testFrom = document.getElementById('testFrom');
      const testTo = document.getElementById('testTo');
      const testInterval = document.getElementById('testInterval');
      const testVsCurrency = document.getElementById('testVsCurrency');
      const assetBaseUrl = '/admin/assets/<%= encodeURIComponent(asset.id) %>/test';

      function toLocalDateTimeInput(date) {
        const offsetMs = date.getTimezoneOffset() * 60000;
        return new Date(date.getTime() - offsetMs).toISOString().slice(0, 16);
      }

      function isoFromInput(input) {
        const value = input.value;
        return value ? new Date(value).toISOString() : '';
      }

      function setAlert(type, message) {
        actionAlert.className = `alert alert-${type}`;
        actionAlert.textContent = message;
      }

      function clearAlert() {
        actionAlert.className = 'alert d-none';
        actionAlert.textContent = '';
      }

      function setStatus(type, message) {
        testStatus.className = `badge text-bg-${type}`;
        testStatus.textContent = message;
      }

      function buildQuery() {
        const params = new URLSearchParams({
          from: isoFromInput(testFrom),
          to: isoFromInput(testTo),
          interval: testInterval.value,
          vsCurrency: testVsCurrency.value
        });

        return params.toString();
      }

      async function runAction(action) {
        clearAlert();
        setStatus('secondary', 'Running');
        testResponse.textContent = 'Running test...';

        const method = action === 'coingecko' || action === 'fetch-recent' ? 'POST' : 'GET';
        const response = await fetch(`${assetBaseUrl}/${action}?${buildQuery()}`, {
          method,
          headers: { Accept: 'application/json' }
        });
        const rawBody = await response.text();
        let data;

        try {
          data = JSON.parse(rawBody);
        } catch (error) {
          data = { error: { message: rawBody || `${response.status} ${response.statusText}` } };
        }

        testResponse.textContent = JSON.stringify(data, null, 2);

        if (!response.ok) {
          const message = data.error && data.error.message ? data.error.message : `${response.status} ${response.statusText}`;
          setStatus('danger', 'Failed');
          setAlert('danger', message);
          return;
        }

        setStatus('success', `${response.status} ${response.statusText}`);
        setAlert('success', `${action.replace('-', ' ')} completed successfully.`);
      }

      document.querySelectorAll('[data-action]').forEach((button) => {
        button.addEventListener('click', () => {
          runAction(button.dataset.action).catch((error) => {
            setStatus('danger', 'Failed');
            setAlert('danger', error.message);
            testResponse.textContent = error.message;
          });
        });
      });

      const now = new Date();
      testTo.value = toLocalDateTimeInput(now);
      testFrom.value = toLocalDateTimeInput(new Date(now.getTime() - (2 * 24 * 60 * 60 * 1000)));
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
