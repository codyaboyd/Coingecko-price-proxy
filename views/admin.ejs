<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/public/css/app.css" rel="stylesheet">
  </head>
  <body>
    <nav class="navbar navbar-expand-lg bg-dark navbar-dark">
      <div class="container">
        <a class="navbar-brand" href="/admin"><%= status.appName %></a>
        <div class="navbar-nav ms-auto">
          <a class="nav-link" href="/admin/api-test">API Test</a>
        </div>
      </div>
    </nav>

    <main class="container py-5">
      <div class="p-4 p-md-5 mb-4 rounded text-body-emphasis bg-body-secondary">
        <h1 class="display-6 fw-bold"><%= title %></h1>
        <p class="lead mb-0">Server-rendered admin shell for cache configuration and future price data operations.</p>
      </div>

      <div class="row g-3 mb-4">
        <div class="col-sm-6 col-xl-3">
          <div class="card shadow-sm h-100">
            <div class="card-body">
              <p class="text-uppercase text-secondary small fw-semibold mb-1">Queue depth</p>
              <p class="display-6 mb-0"><%= queue.depth %></p>
            </div>
          </div>
        </div>
        <div class="col-sm-6 col-xl-3">
          <div class="card shadow-sm h-100">
            <div class="card-body">
              <p class="text-uppercase text-secondary small fw-semibold mb-1">Active job</p>
              <p class="h6 mb-0 text-truncate" title="<%= queue.activeJobLabel %>"><%= queue.activeJobLabel %></p>
            </div>
          </div>
        </div>
        <div class="col-sm-6 col-xl-3">
          <div class="card shadow-sm h-100">
            <div class="card-body">
              <p class="text-uppercase text-secondary small fw-semibold mb-1">Recent failures</p>
              <p class="display-6 mb-0"><%= queue.recentFailures.length %></p>
            </div>
          </div>
        </div>
        <div class="col-sm-6 col-xl-3">
          <div class="card shadow-sm h-100">
            <div class="card-body">
              <p class="text-uppercase text-secondary small fw-semibold mb-1">Calls used this minute</p>
              <p class="display-6 mb-0"><%= queue.callsUsedThisMinute === null ? '—' : queue.callsUsedThisMinute %></p>
            </div>
          </div>
        </div>
      </div>

      <% if (queue.recentFailures.length > 0) { %>
        <div class="alert alert-warning" role="alert">
          <div class="fw-semibold mb-2">Recent job failures</div>
          <ul class="mb-0">
            <% queue.recentFailures.forEach((job) => { %>
              <li><code>#<%= job.id %></code> <%= job.type %> for <%= job.payload.assetId || 'n/a' %>: <%= job.error %></li>
            <% }) %>
          </ul>
        </div>
      <% } %>

      <div class="row g-4">
        <section class="col-lg-8">
          <div class="card shadow-sm">
            <div class="card-header bg-white">
              <h2 class="h5 mb-0">Configured assets</h2>
            </div>
            <div class="table-responsive">
              <table class="table table-striped table-hover mb-0 align-middle">
                <thead>
                  <tr>
                    <th scope="col">Symbol</th>
                    <th scope="col">Name</th>
                    <th scope="col">CoinGecko ID</th>
                    <th scope="col">Currency</th>
                    <th scope="col">Priority</th>
                    <th scope="col">Status</th>
                    <th scope="col">Admin</th>
                    <th scope="col">API</th>
                  </tr>
                </thead>
                <tbody>
                  <% assets.forEach((asset) => { %>
                    <tr>
                      <td class="fw-semibold"><%= asset.symbol %></td>
                      <td><%= asset.name %></td>
                      <td><code><%= asset.coingeckoId %></code></td>
                      <td class="text-uppercase"><%= asset.vsCurrency %></td>
                      <td><%= asset.priority %></td>
                      <td>
                        <% if (asset.enabled) { %>
                          <span class="badge text-bg-success">Enabled</span>
                        <% } else { %>
                          <span class="badge text-bg-secondary">Disabled</span>
                        <% } %>
                      </td>
                      <td><a href="/admin/assets/<%= asset.id %>" class="btn btn-sm btn-primary">Manage</a></td>
                      <td><a href="/api/v1/assets/<%= asset.id %>" class="btn btn-sm btn-outline-primary">JSON</a></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </section>

        <aside class="col-lg-4">
          <div class="card shadow-sm">
            <div class="card-header bg-white">
              <h2 class="h5 mb-0">System</h2>
            </div>
            <div class="card-body">
              <dl class="mb-0">
                <dt>App name</dt>
                <dd><%= status.appName %></dd>
                <dt>Runtime</dt>
                <dd><code><%= status.runtime %></code></dd>
                <dt>Assets loaded</dt>
                <dd><%= status.assetsLoaded %></dd>
                <dt>Config path</dt>
                <dd><code><%= status.configPath %></code></dd>
                <dt>Database path</dt>
                <dd><code><%= status.databasePath %></code></dd>
                <dt>Health check</dt>
                <dd><a href="/health">/health</a></dd>
                <dt>Public API</dt>
                <dd>
                  <div class="list-group list-group-flush">
                    <a class="list-group-item list-group-item-action px-0" href="/api/v1/health">GET /api/v1/health</a>
                    <a class="list-group-item list-group-item-action px-0" href="/api/v1/assets">GET /api/v1/assets</a>
                    <a class="list-group-item list-group-item-action px-0" href="/api/v1/history/btc">GET /api/v1/history/:assetId</a>
                    <a class="list-group-item list-group-item-action px-0" href="/admin/api-test">Admin API test page</a>
                  </div>
                </dd>
                <dt>Fetching</dt>
                <dd>Manual fetches and backfills are processed by the in-process job queue.</dd>
              </dl>
            </div>
          </div>
        </aside>
      </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
