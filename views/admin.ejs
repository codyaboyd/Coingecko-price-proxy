<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/public/css/app.css" rel="stylesheet">
  </head>
  <body>
    <nav class="navbar navbar-expand-lg bg-dark navbar-dark">
      <div class="container">
        <a class="navbar-brand" href="/admin"><%= status.appName %></a>
        <div class="navbar-nav ms-auto">
          <a class="nav-link" href="/admin/assets">Assets</a>
          <a class="nav-link" href="/admin/imports">Imports</a>
          <a class="nav-link" href="/admin/backups">Backups</a>
          <a class="nav-link" href="/admin/reload-status">Reload Status</a>
          <a class="nav-link" href="/admin/system-health">System Health</a>
          <a class="nav-link" href="/admin/api-test">API Test</a>
          <a class="nav-link" href="/admin/logout">Logout</a>
        </div>
      </div>
    </nav>

    <%- include('admin-maintenance-banner') %>

    <main class="container py-5">
      <div class="p-4 p-md-5 mb-4 rounded text-body-emphasis bg-body-secondary">
        <h1 class="display-6 fw-bold"><%= title %></h1>
        <p class="lead mb-0">Server-rendered admin shell for cache configuration and future price data operations.</p>
      </div>

      <div class="card shadow-sm mb-4 border-warning">
        <div class="card-header bg-warning-subtle d-flex align-items-center justify-content-between flex-wrap gap-2">
          <div>
            <h2 class="h5 mb-1">Maintenance mode</h2>
            <p class="text-secondary small mb-0">Safe solo operation disables CoinGecko fetch jobs and imports while keeping admin and public local history available.</p>
          </div>
          <% if (status.maintenanceMode) { %>
            <span class="badge text-bg-warning">Enabled</span>
          <% } else { %>
            <span class="badge text-bg-success">Disabled</span>
          <% } %>
        </div>
        <div class="card-body d-flex align-items-center justify-content-between flex-wrap gap-3">
          <p class="mb-0">
            <% if (status.maintenanceMode) { %>
              Scheduler is paused due to maintenance; imports and CoinGecko fetch actions are blocked.
            <% } else { %>
              Automatic refresh and import operations are allowed.
            <% } %>
          </p>
          <form method="post" action="/admin/maintenance" class="m-0">
            <input type="hidden" name="mode" value="<%= status.maintenanceMode ? 'off' : 'on' %>">
            <button type="submit" class="btn <%= status.maintenanceMode ? 'btn-outline-success' : 'btn-outline-warning' %>">
              Turn maintenance <%= status.maintenanceMode ? 'off' : 'on' %>
            </button>
          </form>
        </div>
      </div>

      <div class="row g-3 mb-4">
        <div class="col-sm-6 col-xl-3">
          <div class="card shadow-sm h-100">
            <div class="card-body">
              <p class="text-uppercase text-secondary small fw-semibold mb-1">Queue depth</p>
              <p class="display-6 mb-0"><%= queue.depth %></p>
            </div>
          </div>
        </div>
        <div class="col-sm-6 col-xl-3">
          <div class="card shadow-sm h-100">
            <div class="card-body">
              <p class="text-uppercase text-secondary small fw-semibold mb-1">Active job</p>
              <p class="h6 mb-0 text-truncate" title="<%= queue.activeJobLabel %>"><%= queue.activeJobLabel %></p>
            </div>
          </div>
        </div>
        <div class="col-sm-6 col-xl-3">
          <div class="card shadow-sm h-100">
            <div class="card-body">
              <p class="text-uppercase text-secondary small fw-semibold mb-1">Recent failures</p>
              <p class="display-6 mb-0"><%= queue.recentFailures.length %></p>
            </div>
          </div>
        </div>
        <div class="col-sm-6 col-xl-3">
          <div class="card shadow-sm h-100">
            <div class="card-body">
              <p class="text-uppercase text-secondary small fw-semibold mb-1">Calls used this minute</p>
              <p class="display-6 mb-0"><%= queue.callsUsedThisMinute === null ? '—' : queue.callsUsedThisMinute %></p>
            </div>
          </div>
        </div>
      </div>

      <% if (schedulerAction) { %>
        <div class="alert alert-info alert-dismissible fade show" role="alert">
          Scheduler action: <strong><%= schedulerAction %></strong><% if (schedulerDetails) { %> — <%= schedulerDetails %><% } %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% } %>

      <% if (cacheAction) { %>
        <div class="alert alert-info alert-dismissible fade show" role="alert">
          Cache action: <strong><%= cacheAction %></strong><% if (cacheDetails) { %> — <%= cacheDetails %><% } %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% } %>

      <div class="card shadow-sm mb-4">
        <div class="card-header bg-white d-flex align-items-center justify-content-between flex-wrap gap-2">
          <div>
            <h2 class="h5 mb-1">Durable job queue</h2>
            <p class="text-secondary small mb-0">Jobs are persisted in SQLite and recovered across restarts.</p>
          </div>
          <span class="badge text-bg-secondary"><%= queue.queuedJobs.length %> queued · <%= queue.runningJobs.length %> running · <%= queue.failedJobs.length %> failed</span>
        </div>
        <div class="card-body">
          <h3 class="h6">Queued jobs</h3>
          <% if (queue.queuedJobs.length === 0) { %>
            <p class="text-secondary small">No queued jobs.</p>
          <% } else { %>
            <div class="table-responsive mb-3">
              <table class="table table-sm align-middle">
                <thead><tr><th>ID</th><th>Type</th><th>Asset</th><th>Attempts</th><th>Run after</th><th>Action</th></tr></thead>
                <tbody>
                  <% queue.queuedJobs.forEach((job) => { %>
                    <tr>
                      <td><code>#<%= job.id %></code></td>
                      <td><%= job.type %> <span class="badge text-bg-light"><%= job.status %></span></td>
                      <td><%= job.payload.assetId || 'n/a' %></td>
                      <td><%= job.attempts %>/<%= job.maxAttempts %></td>
                      <td><%= job.runAfter ? new Date(job.runAfter).toISOString() : 'now' %></td>
                      <td>
                        <form method="post" action="/admin/jobs/<%= job.id %>/cancel" class="m-0">
                          <button type="submit" class="btn btn-outline-danger btn-sm">Cancel</button>
                        </form>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>

          <h3 class="h6">Running job</h3>
          <% if (queue.runningJobs.length === 0) { %>
            <p class="text-secondary small">No running job.</p>
          <% } else { %>
            <div class="table-responsive mb-3">
              <table class="table table-sm align-middle">
                <thead><tr><th>ID</th><th>Type</th><th>Asset</th><th>Attempts</th><th>Locked at</th><th>Action</th></tr></thead>
                <tbody>
                  <% queue.runningJobs.forEach((job) => { %>
                    <tr>
                      <td><code>#<%= job.id %></code></td>
                      <td><%= job.type %></td>
                      <td><%= job.payload.assetId || 'n/a' %></td>
                      <td><%= job.attempts %>/<%= job.maxAttempts %></td>
                      <td><%= job.lockedAt ? new Date(job.lockedAt).toISOString() : '—' %></td>
                      <td>
                        <form method="post" action="/admin/jobs/<%= job.id %>/cancel" class="m-0">
                          <button type="submit" class="btn btn-outline-danger btn-sm">Cancel</button>
                        </form>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>

          <h3 class="h6">Failed jobs</h3>
          <% if (queue.failedJobs.length === 0) { %>
            <p class="text-secondary small mb-0">No failed jobs.</p>
          <% } else { %>
            <div class="table-responsive">
              <table class="table table-sm align-middle">
                <thead><tr><th>ID</th><th>Type</th><th>Asset</th><th>Attempts</th><th>Error</th><th>Action</th></tr></thead>
                <tbody>
                  <% queue.failedJobs.forEach((job) => { %>
                    <tr>
                      <td><code>#<%= job.id %></code></td>
                      <td><%= job.type %></td>
                      <td><%= job.payload.assetId || 'n/a' %></td>
                      <td><%= job.attempts %>/<%= job.maxAttempts %></td>
                      <td class="text-break"><%= job.lastError || 'Unknown error' %></td>
                      <td>
                        <form method="post" action="/admin/jobs/<%= job.id %>/retry" class="m-0">
                          <button type="submit" class="btn btn-outline-primary btn-sm">Retry</button>
                        </form>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </div>

      <div class="card shadow-sm mb-4">
        <div class="card-header bg-white d-flex align-items-center justify-content-between flex-wrap gap-2">
          <div>
            <h2 class="h5 mb-1">Recent refresh scheduler</h2>
            <p class="text-secondary small mb-0">In-memory automatic refresh for enabled assets only.</p>
          </div>
          <% if (recentRefresh.pauseReason === 'maintenance') { %>
            <span class="badge text-bg-warning">Paused due to maintenance</span>
          <% } else if (recentRefresh.paused) { %>
            <span class="badge text-bg-warning">Paused</span>
          <% } else { %>
            <span class="badge text-bg-success">Running</span>
          <% } %>
        </div>
        <div class="card-body">
          <div class="row g-3 mb-3">
            <div class="col-md-3">
              <p class="text-uppercase text-secondary small fw-semibold mb-1">Enabled assets</p>
              <p class="h4 mb-0"><%= recentRefresh.configuredAssets %></p>
            </div>
            <div class="col-md-3">
              <p class="text-uppercase text-secondary small fw-semibold mb-1">Runs</p>
              <p class="h4 mb-0"><%= recentRefresh.runCount %></p>
            </div>
            <div class="col-md-3">
              <p class="text-uppercase text-secondary small fw-semibold mb-1">Last run</p>
              <p class="mb-0"><%= recentRefresh.lastRunAtIso || 'Never' %></p>
            </div>
            <div class="col-md-3">
              <p class="text-uppercase text-secondary small fw-semibold mb-1">Next run</p>
              <p class="mb-0"><%= recentRefresh.pauseReason === 'maintenance' ? 'Paused due to maintenance' : (recentRefresh.nextRunAtIso || 'Not scheduled') %></p>
            </div>
          </div>

          <% if (recentRefresh.lastError) { %>
            <div class="alert alert-warning" role="alert"><%= recentRefresh.lastError %></div>
          <% } %>

          <% if (recentRefresh.pauseReason === 'maintenance') { %>
            <div class="alert alert-warning" role="alert">Scheduler controls are disabled because maintenance mode is active.</div>
          <% } %>
          <form class="d-inline" method="post" action="/admin/scheduler/repair-stale">
            <button type="submit" class="btn btn-danger" <%= recentRefresh.pauseReason === 'maintenance' ? 'disabled' : '' %>>Repair stale data now</button>
          </form>
          <form class="d-inline" method="post" action="/admin/scheduler/run-now">
            <button type="submit" class="btn btn-primary" <%= recentRefresh.pauseReason === 'maintenance' ? 'disabled' : '' %>>Run refresh now</button>
          </form>
          <% if (recentRefresh.paused) { %>
            <form class="d-inline" method="post" action="/admin/scheduler/resume">
              <button type="submit" class="btn btn-outline-success">Resume scheduler</button>
            </form>
          <% } else { %>
            <form class="d-inline" method="post" action="/admin/scheduler/pause">
              <button type="submit" class="btn btn-outline-warning">Pause scheduler</button>
            </form>
          <% } %>

          <div class="table-responsive mt-3">
            <table class="table table-sm align-middle mb-0">
              <thead>
                <tr>
                  <th scope="col">Asset</th>
                  <th scope="col">Policy</th>
                  <th scope="col">Intervals</th>
                  <th scope="col">Last jobs</th>
                </tr>
              </thead>
              <tbody>
                <% recentRefresh.assets.forEach((assetState) => { %>
                  <tr>
                    <td><span class="fw-semibold"><%= assetState.symbol %></span> <code><%= assetState.assetId %></code></td>
                    <td>
                      Every <%= assetState.policy.recentEveryMinutes %> min,
                      daily backfill <%= assetState.policy.dailyBackfill ? 'on' : 'off' %>,
                      max <%= assetState.policy.maxBackfillDaysPerRun %> day(s)
                    </td>
                    <td>
                      <% Object.entries(assetState.intervals).forEach(([interval, intervalState]) => { %>
                        <div><code><%= interval %></code> next <%= intervalState.nextRunAt ? new Date(intervalState.nextRunAt).toISOString() : '—' %></div>
                      <% }) %>
                    </td>
                    <td><%= assetState.lastRunJobCount %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>


      <div class="card shadow-sm mb-4">
        <div class="card-header bg-white d-flex align-items-center justify-content-between flex-wrap gap-2">
          <div>
            <h2 class="h5 mb-1">Hot reload status</h2>
            <p class="text-secondary small mb-0">Runtime config reloads and pending import candidates.</p>
          </div>
          <% if (reloadStatus.lastReload.status === 'success') { %>
            <span class="badge text-bg-success">Success</span>
          <% } else if (reloadStatus.lastReload.status === 'error') { %>
            <span class="badge text-bg-danger">Error</span>
          <% } else { %>
            <span class="badge text-bg-secondary"><%= reloadStatus.lastReload.status %></span>
          <% } %>
        </div>
        <div class="card-body">
          <div class="row g-3 mb-3">
            <div class="col-md-4">
              <p class="text-uppercase text-secondary small fw-semibold mb-1">Last reload time</p>
              <p class="mb-0"><%= reloadStatus.lastReloadAtIso || 'Never' %></p>
            </div>
            <div class="col-md-4">
              <p class="text-uppercase text-secondary small fw-semibold mb-1">Last reload target</p>
              <p class="mb-0"><code><%= reloadStatus.lastReload.target %></code></p>
            </div>
            <div class="col-md-4">
              <p class="text-uppercase text-secondary small fw-semibold mb-1">Pending imports</p>
              <p class="h4 mb-0"><%= reloadStatus.importCandidates.length %></p>
            </div>
          </div>
          <p class="mb-2"><%= reloadStatus.lastReload.message %></p>
          <% if (reloadStatus.lastReload.errors.length > 0) { %>
            <div class="alert alert-warning" role="alert">
              <div class="fw-semibold mb-2">Last reload errors</div>
              <ul class="mb-0">
                <% reloadStatus.lastReload.errors.forEach((error) => { %>
                  <li><%= error %></li>
                <% }) %>
              </ul>
            </div>
          <% } %>
          <% if (reloadStatus.lastReload.restartRequiredSettings.length > 0) { %>
            <div class="alert alert-info" role="alert">
              Restart required for: <code><%= reloadStatus.lastReload.restartRequiredSettings.join(', ') %></code>
            </div>
          <% } %>
          <div class="d-flex gap-2 flex-wrap">
            <a href="/admin/reload-status" class="btn btn-outline-primary btn-sm">View reload dashboard</a>
            <a href="/admin/imports" class="btn btn-primary btn-sm">Open import page</a>
          </div>
        </div>
      </div>

      <div class="card shadow-sm mb-4">
        <div class="card-header bg-white d-flex align-items-center justify-content-between flex-wrap gap-2">
          <div>
            <h2 class="h5 mb-1">API response cache</h2>
            <p class="text-secondary small mb-0">Local cache for GET /api/v1/history/:assetId responses.</p>
          </div>
          <form method="post" action="/admin/cache/clear" class="m-0">
            <button type="submit" class="btn btn-outline-danger btn-sm">Clear cache</button>
          </form>
        </div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-sm-6">
              <p class="text-uppercase text-secondary small fw-semibold mb-1">Active cache entries</p>
              <p class="display-6 mb-0"><%= cacheStats.activeEntries %></p>
            </div>
            <div class="col-sm-6">
              <p class="text-uppercase text-secondary small fw-semibold mb-1">Expired cache entries</p>
              <p class="display-6 mb-0"><%= cacheStats.expiredEntries %></p>
            </div>
          </div>
        </div>
      </div>

      <% if (queue.recentFailures.length > 0) { %>
        <div class="alert alert-warning" role="alert">
          <div class="fw-semibold mb-2">Recent job failures</div>
          <ul class="mb-0">
            <% queue.recentFailures.forEach((job) => { %>
              <li><code>#<%= job.id %></code> <%= job.type %> for <%= job.payload.assetId || 'n/a' %>: <%= job.error %></li>
            <% }) %>
          </ul>
        </div>
      <% } %>

      <div class="row g-4">
        <section class="col-lg-8">
          <div class="card shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center flex-wrap gap-2">
              <div>
                <h2 class="h5 mb-0">Configured assets</h2>
                <p class="text-secondary small mb-0">Open the full asset admin table for safe config editing.</p>
              </div>
              <a class="btn btn-sm btn-outline-primary" href="/admin/assets">Open assets page</a>
            </div>
            <div class="table-responsive">
              <table class="table table-striped table-hover mb-0 align-middle">
                <thead>
                  <tr>
                    <th scope="col">Symbol</th>
                    <th scope="col">Name</th>
                    <th scope="col">CoinGecko ID</th>
                    <th scope="col">Currency</th>
                    <th scope="col">Priority</th>
                    <th scope="col">Status</th>
                    <th scope="col">Admin</th>
                    <th scope="col">API</th>
                  </tr>
                </thead>
                <tbody>
                  <% assets.forEach((asset) => { %>
                    <tr>
                      <td class="fw-semibold"><%= asset.symbol %></td>
                      <td><%= asset.name %></td>
                      <td><code><%= asset.coingeckoId %></code></td>
                      <td class="text-uppercase"><%= asset.vsCurrency %></td>
                      <td><%= asset.priority %></td>
                      <td>
                        <% if (asset.enabled) { %>
                          <span class="badge text-bg-success">Enabled</span>
                        <% } else { %>
                          <span class="badge text-bg-secondary">Disabled</span>
                        <% } %>
                      </td>
                      <td><div class="btn-group btn-group-sm"><a href="/admin/assets/<%= asset.id %>" class="btn btn-outline-primary">Manage</a><a href="/admin/assets/<%= asset.id %>/edit" class="btn btn-primary">Edit</a></div></td>
                      <td><a href="/api/v1/assets/<%= asset.id %>" class="btn btn-sm btn-outline-primary">JSON</a></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </section>

        <aside class="col-lg-4">
          <div class="card shadow-sm">
            <div class="card-header bg-white">
              <h2 class="h5 mb-0">System</h2>
            </div>
            <div class="card-body">
              <dl class="mb-0">
                <dt>App name</dt>
                <dd><%= status.appName %></dd>
                <dt>Runtime</dt>
                <dd><code><%= status.runtime %></code></dd>
                <dt>Assets loaded</dt>
                <dd><%= status.assetsLoaded %></dd>
                <dt>Config path</dt>
                <dd><code><%= status.configPath %></code></dd>
                <dt>Database path</dt>
                <dd><code><%= status.databasePath %></code></dd>
                <dt>Health check</dt>
                <dd><a href="/health">/health</a></dd>
                <dt>Public API</dt>
                <dd>
                  <div class="list-group list-group-flush">
                    <a class="list-group-item list-group-item-action px-0" href="/api/v1/health">GET /api/v1/health</a>
                    <a class="list-group-item list-group-item-action px-0" href="/api/v1/assets">GET /api/v1/assets</a>
                    <a class="list-group-item list-group-item-action px-0" href="/api/v1/history/btc">GET /api/v1/history/:assetId</a>
                    <a class="list-group-item list-group-item-action px-0" href="/admin/system-health">System health dashboard</a>
                    <a class="list-group-item list-group-item-action px-0" href="/admin/api-test">Admin API test page</a>
                    <a class="list-group-item list-group-item-action px-0" href="/admin/imports">Admin import page</a>
                  </div>
                </dd>
                <dt>Fetching</dt>
                <dd>Manual fetches and backfills are processed by the in-process job queue.</dd>
              </dl>
            </div>
          </div>
        </aside>
      </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
