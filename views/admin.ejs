<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/public/css/app.css" rel="stylesheet">
  </head>
  <body>
    <nav class="navbar navbar-expand-lg bg-dark navbar-dark">
      <div class="container">
        <a class="navbar-brand" href="/admin">chrono-cache</a>
        <span class="navbar-text">MVP scaffold</span>
      </div>
    </nav>

    <main class="container py-5">
      <div class="p-4 p-md-5 mb-4 rounded text-body-emphasis bg-body-secondary">
        <h1 class="display-6 fw-bold"><%= title %></h1>
        <p class="lead mb-0">Server-rendered admin shell for cache configuration and future price data operations.</p>
      </div>

      <div class="row g-4">
        <section class="col-lg-8">
          <div class="card shadow-sm">
            <div class="card-header bg-white">
              <h2 class="h5 mb-0">Configured assets</h2>
            </div>
            <div class="table-responsive">
              <table class="table table-striped table-hover mb-0 align-middle">
                <thead>
                  <tr>
                    <th scope="col">Symbol</th>
                    <th scope="col">Name</th>
                    <th scope="col">CoinGecko ID</th>
                    <th scope="col">Currency</th>
                    <th scope="col">Status</th>
                  </tr>
                </thead>
                <tbody>
                  <% assets.forEach((asset) => { %>
                    <tr>
                      <td class="fw-semibold"><%= asset.symbol %></td>
                      <td><%= asset.name %></td>
                      <td><code><%= asset.id %></code></td>
                      <td class="text-uppercase"><%= asset.currency %></td>
                      <td>
                        <% if (asset.enabled) { %>
                          <span class="badge text-bg-success">Enabled</span>
                        <% } else { %>
                          <span class="badge text-bg-secondary">Disabled</span>
                        <% } %>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </section>

        <aside class="col-lg-4">
          <div class="card shadow-sm">
            <div class="card-header bg-white">
              <h2 class="h5 mb-0">System</h2>
            </div>
            <div class="card-body">
              <dl class="mb-0">
                <dt>Health check</dt>
                <dd><a href="/health">/health</a></dd>
                <dt>SQLite database</dt>
                <dd><code><%= databasePath %></code></dd>
                <dt>Fetching</dt>
                <dd>Not implemented yet.</dd>
              </dl>
            </div>
          </div>
        </aside>
      </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
