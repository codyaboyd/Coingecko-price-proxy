<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/public/css/app.css" rel="stylesheet">
    <script src="/public/js/admin-nav.js" defer></script>
  </head>
  <body>
    <nav class="navbar navbar-expand-lg bg-dark navbar-dark">
      <div class="container">
        <a class="navbar-brand" href="/admin"><%= appName %></a>
        <div class="navbar-nav ms-auto">
          <a class="nav-link" href="/admin/settings">Settings</a>
          <a class="nav-link active" href="/admin/assets">Assets</a>
          <a class="nav-link" href="/admin/imports">Imports</a>
          <a class="nav-link" href="/admin/backups">Backups</a>
          <a class="nav-link" href="/admin/system-health">System Health</a>
          <a class="nav-link" href="/admin/db-integrity">DB Integrity</a>
          <a class="nav-link" href="/admin/rate-budget">Rate Budget</a>
          <a class="nav-link" href="/admin/logs">Logs</a>
          <a class="nav-link" href="/admin/api-test">API Test</a>
          <a class="nav-link" href="/admin/runbook">Runbook</a>
          <%- include('admin-alert-bell') %>
          <a class="nav-link" href="/admin/logout">Logout</a>
        </div>
      </div>
    </nav>

    <%- include('admin-maintenance-banner') %>

    <main class="container py-5">
      <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
        <div>
          <h1 class="display-6 fw-bold mb-1">Assets</h1>
          <p class="lead text-body-secondary mb-0">Review configured CoinGecko assets and jump into safe per-asset editing.</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
          <a class="btn btn-primary" href="/admin/assets/new">Add asset</a>
          <a class="btn btn-outline-secondary" href="/admin">Back to dashboard</a>
        </div>
      </div>

      <% if (alert && message) { %>
        <div class="alert alert-<%= alert %> alert-dismissible fade show" role="alert">
          <%= message %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% } %>

      <div class="card shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center flex-wrap gap-2">
          <h2 class="h5 mb-0">Configured assets</h2>
          <span class="badge text-bg-secondary"><%= assets.length %> total</span>
        </div>
        <div class="table-responsive">
          <table class="table table-striped table-hover align-middle mb-0">
            <thead>
              <tr>
                <th scope="col">Symbol</th>
                <th scope="col">Name</th>
                <th scope="col">CoinGecko ID</th>
                <th scope="col">Enabled</th>
                <th scope="col">Priority</th>
                <th scope="col">Staleness</th>
                <th scope="col">Earliest candle</th>
                <th scope="col">Latest candle</th>
                <th scope="col">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (assets.length === 0) { %>
                <tr>
                  <td colspan="9" class="text-body-secondary">No assets are configured.</td>
                </tr>
              <% } %>
              <% assets.forEach((asset) => { %>
                <tr>
                  <td class="fw-semibold"><%= asset.symbol %></td>
                  <td><%= asset.name %></td>
                  <td><code><%= asset.coingeckoId %></code></td>
                  <td>
                    <% if (asset.enabled) { %>
                      <span class="badge text-bg-success">Enabled</span>
                    <% } else { %>
                      <span class="badge text-bg-secondary">Disabled</span>
                    <% } %>
                  </td>
                  <td><%= asset.priority %></td>
                  <td>
                    <% const badgeClasses = { fresh: 'success', stale: 'warning', empty: 'secondary', fetching: 'info', failed: 'danger' }; %>
                    <span class="badge text-bg-<%= badgeClasses[asset.staleness.overallStatus] || 'secondary' %>"><%= asset.staleness.overallStatus %></span>
                    <div class="small text-body-secondary mt-1">
                      <% asset.staleness.intervals.forEach((intervalStatus) => { %>
                        <span class="me-2"><%= intervalStatus.interval %>: <%= intervalStatus.status %></span>
                      <% }) %>
                    </div>
                    <% const errorInterval = asset.staleness.intervals.find((intervalStatus) => intervalStatus.lastError); %>
                    <% if (errorInterval) { %>
                      <div class="small text-danger text-truncate" title="<%= errorInterval.lastError %>"><%= errorInterval.lastError %></div>
                    <% } %>
                  </td>
                  <td><%= asset.earliestIso || '—' %></td>
                  <td><%= asset.latestIso || '—' %></td>
                  <td>
                    <div class="btn-group btn-group-sm" role="group" aria-label="Asset actions">
                      <a class="btn btn-outline-primary" href="/admin/assets/<%= encodeURIComponent(asset.id) %>">Manage</a>
                      <a class="btn btn-primary" href="/admin/assets/<%= encodeURIComponent(asset.id) %>/edit">Edit</a>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
