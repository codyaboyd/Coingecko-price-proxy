<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/public/css/app.css" rel="stylesheet">
  </head>
  <body>
    <nav class="navbar navbar-expand-lg bg-dark navbar-dark">
      <div class="container">
        <a class="navbar-brand" href="/admin"><%= appName %></a>
        <div class="navbar-nav ms-auto">
          <a class="nav-link" href="/admin/settings">Settings</a>
          <a class="nav-link active" href="/admin/reload-status">Reload Status</a>
          <a class="nav-link" href="/admin/system-health">System Health</a>
          <a class="nav-link" href="/admin/db-integrity">DB Integrity</a>
          <a class="nav-link" href="/admin/rate-budget">Rate Budget</a>
          <a class="nav-link" href="/admin/assets">Assets</a>
          <a class="nav-link" href="/admin/logs">Logs</a>
          <a class="nav-link" href="/admin/api-test">API Test</a>
          <a class="nav-link" href="/admin/runbook">Runbook</a>
          <%- include('admin-alert-bell') %>
          <a class="nav-link" href="/admin/logout">Logout</a>
        </div>
      </div>
    </nav>

    <%- include('admin-maintenance-banner') %>

    <main class="container py-5">
      <div class="d-flex align-items-start justify-content-between flex-wrap gap-3 mb-4">
        <div>
          <h1 class="display-6 fw-bold mb-1">Reload Status</h1>
          <p class="text-secondary mb-0">Hot reload state for asset config, server config, and import candidates.</p>
        </div>
        <a href="/admin" class="btn btn-outline-secondary">Back to dashboard</a>
      </div>

      <section class="card shadow-sm mb-4">
        <div class="card-header bg-white d-flex align-items-center justify-content-between flex-wrap gap-2">
          <h2 class="h5 mb-0">Last reload</h2>
          <% if (reloadStatus.lastReload.status === 'success') { %>
            <span class="badge text-bg-success">Success</span>
          <% } else if (reloadStatus.lastReload.status === 'error') { %>
            <span class="badge text-bg-danger">Error</span>
          <% } else { %>
            <span class="badge text-bg-secondary"><%= reloadStatus.lastReload.status %></span>
          <% } %>
        </div>
        <div class="card-body">
          <dl class="row mb-0">
            <dt class="col-sm-3">Time</dt>
            <dd class="col-sm-9"><%= reloadStatus.lastReloadAtIso || 'Never' %></dd>
            <dt class="col-sm-3">Target</dt>
            <dd class="col-sm-9"><code><%= reloadStatus.lastReload.target %></code></dd>
            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9"><%= reloadStatus.lastReload.status %></dd>
            <dt class="col-sm-3">Message</dt>
            <dd class="col-sm-9"><%= reloadStatus.lastReload.message %></dd>
            <dt class="col-sm-3">Changed settings</dt>
            <dd class="col-sm-9"><%= reloadStatus.lastReload.changedSettings.length ? reloadStatus.lastReload.changedSettings.join(', ') : 'None' %></dd>
            <dt class="col-sm-3">Restart required</dt>
            <dd class="col-sm-9"><%= reloadStatus.lastReload.restartRequiredSettings.length ? reloadStatus.lastReload.restartRequiredSettings.join(', ') : 'None' %></dd>
          </dl>
          <% if (reloadStatus.lastReload.errors.length > 0) { %>
            <div class="alert alert-warning mt-3 mb-0" role="alert">
              <div class="fw-semibold mb-2">Errors</div>
              <ul class="mb-0">
                <% reloadStatus.lastReload.errors.forEach((error) => { %>
                  <li><%= error %></li>
                <% }) %>
              </ul>
            </div>
          <% } %>
        </div>
      </section>

      <section class="card shadow-sm mb-4">
        <div class="card-header bg-white">
          <h2 class="h5 mb-0">Pending import candidates</h2>
        </div>
        <div class="table-responsive">
          <table class="table table-striped mb-0 align-middle">
            <thead>
              <tr>
                <th scope="col">File</th>
                <th scope="col">Status</th>
                <th scope="col">Size</th>
                <th scope="col">First seen</th>
                <th scope="col">Updated</th>
              </tr>
            </thead>
            <tbody>
              <% if (reloadStatus.importCandidates.length === 0) { %>
                <tr><td colspan="5" class="text-secondary">No pending imports detected.</td></tr>
              <% } %>
              <% reloadStatus.importCandidates.forEach((candidate) => { %>
                <tr>
                  <td><code><%= candidate.fileName %></code><div class="small text-secondary"><%= candidate.path %></div></td>
                  <td><span class="badge text-bg-warning"><%= candidate.status %></span></td>
                  <td><%= candidate.size %> bytes</td>
                  <td><%= candidate.firstSeenAtIso %></td>
                  <td><%= candidate.updatedAtIso %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>

      <section class="card shadow-sm">
        <div class="card-header bg-white">
          <h2 class="h5 mb-0">Recent reload events</h2>
        </div>
        <div class="table-responsive">
          <table class="table table-sm mb-0 align-middle">
            <thead>
              <tr>
                <th scope="col">Time</th>
                <th scope="col">Target</th>
                <th scope="col">Status</th>
                <th scope="col">Message</th>
              </tr>
            </thead>
            <tbody>
              <% if (reloadStatus.events.length === 0) { %>
                <tr><td colspan="4" class="text-secondary">No reload events recorded.</td></tr>
              <% } %>
              <% reloadStatus.events.forEach((event) => { %>
                <tr>
                  <td><%= event.atIso %></td>
                  <td><code><%= event.target %></code></td>
                  <td><%= event.status %></td>
                  <td>
                    <%= event.message %>
                    <% if (event.errors.length > 0) { %>
                      <ul class="mb-0 small text-danger">
                        <% event.errors.forEach((error) => { %>
                          <li><%= error %></li>
                        <% }) %>
                      </ul>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
