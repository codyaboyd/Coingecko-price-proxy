{
  "id": "aggressive",
  "name": "Aggressive",
  "description": "Faster refreshes and backfills while still routing all CoinGecko traffic through the configured rate limiter.",
  "coingecko": {
    "maxCallsPerMinute": 45,
    "safeMode": true,
