  "automation": {
    "recentEveryMinutes": 15,
    "dailyBackfill": true,
    "maxBackfillDaysPerRun": 30,
    "enable5m": false,
    "failureThreshold": 3,
    "failureCooldownMinutes": 10
  }
}
