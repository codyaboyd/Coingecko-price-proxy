{
  "id": "conservative",
  "name": "Conservative",
  "description": "Lowest CoinGecko call rate, long cooldowns, and fewer automatic backfills for free-tier set-and-forget installs.",
  "coingecko": {
    "maxCallsPerMinute": 8,
    "safeMode": true,
    "rateLimitPauseMs": 120000,
    "retries": 1,
    "baseBackoffMs": 3000
  },
  "automation": {
    "recentEveryMinutes": 120,
    "dailyBackfill": false,
    "maxBackfillDaysPerRun": 3,
    "enable5m": false,
    "failureThreshold": 3,
    "failureCooldownMinutes": 60
  }
}
