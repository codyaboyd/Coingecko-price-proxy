# App
APP_NAME=chrono-cache
NODE_ENV=development
LOG_LEVEL=info

# Server
PORT=3000
HOST=127.0.0.1

# Database
# Set to true to skip automatic migrations on server startup.
DISABLE_AUTO_MIGRATE=false
# Set to false to skip automatic migrations on server startup.
AUTO_MIGRATE=true

# Paths
CONFIG_DIR=./config
DATA_DIR=./data
LOG_DIR=./logs
DB_PATH=./data/history.sqlite
ASSETS_CONFIG_PATH=./config/assets.json

# Admin
# Change these before exposing the app to a network.
ADMIN_TITLE=Chrono Cache Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret

# Public API rate limiting
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=120

# CoinGecko
# Free-tier conservative defaults. Failed requests count toward the local budget.
COINGECKO_API_BASE=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=
# One of: none, demo, pro. Use none when COINGECKO_API_KEY is blank.
COINGECKO_API_KEY_TYPE=none
COINGECKO_MAX_CALLS_PER_MINUTE=8
COINGECKO_SAFE_MODE=true
COINGECKO_TIMEOUT_MS=15000
COINGECKO_RATE_LIMIT_PAUSE_MS=120000
COINGECKO_RETRIES=1
COINGECKO_BACKOFF_MS=3000

# Optional alert webhook target. Leave blank to disable outbound alert webhooks.
ALERT_WEBHOOK_URL=
