# App
APP_NAME=chrono-cache
NODE_ENV=development
LOG_LEVEL=info

# Server
PORT=3000
HOST=127.0.0.1

# Database
# Set to true to skip automatic migrations on server startup.
DISABLE_AUTO_MIGRATE=false

# Paths
CONFIG_DIR=./config
DATA_DIR=./data
LOG_DIR=./logs
DB_PATH=./data/history.sqlite
ASSETS_CONFIG_PATH=./config/assets.json

# Admin
ADMIN_TITLE=Chrono Cache Admin
