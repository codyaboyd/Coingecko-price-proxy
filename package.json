{
  "name": "chrono-cache",
  "version": "0.1.0",
  "description": "MVP scaffold for a server-rendered cryptocurrency cache admin app.",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "node scripts/cli.js migrate",
    "validate-assets": "node scripts/cli.js validate-assets",
    "import": "node scripts/import-history.js",
    "convert": "node scripts/convert.js",
    "backup": "node scripts/cli.js backup",
    "seed:fake-btc": "node scripts/seed-fake-btc-candles.js",
    "verify:history": "node scripts/verify-history-service.js",
    "cg:test": "node scripts/cli.js cg-test",
    "verify:history-normalizer": "node scripts/verify-history-normalizer.js",
    "verify:cache-policy": "node scripts/verify-cache-policy.js",
    "backup-db": "node scripts/cli.js backup-db",
    "export-history": "node scripts/cli.js export-history",
    "repair-gaps": "node scripts/cli.js repair-gaps",
    "queue-status": "node scripts/cli.js queue-status",
    "test": "node --test tests/smoke.test.js",
    "smoke": "node --test tests/smoke.test.js",
    "self-check": "node scripts/self-check.js",
    "backups:list": "node scripts/cli.js backups:list",
    "backups:prune": "node scripts/cli.js backups:prune",
    "restore": "node scripts/restore-backup.js",
    "maintenance:on": "node scripts/cli.js maintenance:on",
    "maintenance:off": "node scripts/cli.js maintenance:off",
    "jobs:list": "node scripts/cli.js jobs:list",
    "jobs:retry-failed": "node scripts/cli.js jobs:retry-failed",
    "jobs:clear-completed": "node scripts/cli.js jobs:clear-completed",
    "db:check": "node scripts/cli.js db:check",
    "bundle": "node scripts/create-portable-bundle.js"
  },
  "keywords": [
    "cache",
    "crypto",
    "sqlite",
    "express"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "chokidar": "^4.0.3",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "helmet": "^8.1.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
